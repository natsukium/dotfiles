		{
			"type": "table",
			"title": "Active Alerts",
			"description": "Every alert Prometheus currently holds in pending or firing state.",
			"gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
			"id": 5,
			"datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
			"targets": [
				{
					"refId": "A",
					"datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
					"editorMode": "code",
					"expr": "ALERTS",
					"format": "table",
					"instant": true,
					"range": false
				}
			],
			"transformations": [
				{
					"id": "organize",
					"options": {
						"excludeByName": { "Time": true, "Value": true, "__name__": true },
						"indexByName": {
							"alertname": 0,
							"alertstate": 1,
							"severity": 2,
							"instance": 3,
							"job": 4
						},
						"renameByName": {}
					}
				},
				{
					"id": "sortBy",
					"options": {
						"fields": {},
						"sort": [{ "field": "alertstate", "desc": true }]
					}
				}
			],
			"options": {
				"showHeader": true,
				"cellHeight": "sm",
				"footer": {
					"show": false,
					"reducer": ["sum"],
					"countRows": false,
					"fields": ""
				}
			},
			"fieldConfig": {
				"defaults": {
					"custom": {
						"align": "auto",
						"cellOptions": { "type": "auto" },
						"filterable": true
					}
				},
				"overrides": [
					{
						"matcher": { "id": "byName", "options": "alertstate" },
						"properties": [
							{
								"id": "custom.cellOptions",
								"value": { "type": "color-text" }
							},
							{
								"id": "mappings",
								"value": [
									{
										"type": "value",
										"options": {
											"firing": { "color": "red", "index": 0 },
											"pending": { "color": "yellow", "index": 1 }
										}
									}
								]
							}
						]
					},
					{
						"matcher": { "id": "byName", "options": "severity" },
						"properties": [
							{
								"id": "custom.cellOptions",
								"value": { "type": "color-text" }
							},
							{
								"id": "mappings",
								"value": [
									{
										"type": "value",
										"options": {
											"critical": { "color": "red", "index": 0 },
											"warning": { "color": "orange", "index": 1 }
										}
									}
								]
							}
						]
					}
				]
			}
		},
		{
			"type": "timeseries",
			"title": "Service Probe Success",
			"description": "Blackbox HTTP probes against each service on loopback. 1 = responding.",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
			"id": 6,
			"datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
			"targets": [
				{
					"refId": "A",
					"datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
					"editorMode": "code",
					"expr": "probe_success",
					"legendFormat": "{{instance}}",
					"range": true
				}
			],
			"options": {
				"legend": {
					"displayMode": "table",
					"placement": "bottom",
					"showLegend": true,
					"calcs": ["lastNotNull"]
				},
				"tooltip": { "mode": "multi", "sort": "none" }
			},
			"fieldConfig": {
				"defaults": {
					"min": 0,
					"max": 1,
					"unit": "short",
					"custom": {
						"drawStyle": "line",
						"lineInterpolation": "stepAfter",
						"lineWidth": 2,
						"fillOpacity": 10,
						"showPoints": "never",
						"spanNulls": false
					},
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "red", "value": null },
							{ "color": "green", "value": 1 }
						]
					},
					"color": { "mode": "thresholds" }
				},
				"overrides": []
			}
		},
		{
			"type": "timeseries",
			"title": "Probe Duration",
			"description": "How long each probe took. A rising trend precedes an outright probe failure.",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
			"id": 7,
			"datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
			"targets": [
				{
					"refId": "A",
					"datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
					"editorMode": "code",
					"expr": "probe_duration_seconds",
					"legendFormat": "{{instance}}",
					"range": true
