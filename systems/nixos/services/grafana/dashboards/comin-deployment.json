			"title": "Git Fetch Statistics",
			"transformations": [
				{
					"id": "joinByField",
					"options": {
						"byField": "instance",
						"mode": "outer"
					}
				},
				{
					"id": "filterFieldsByName",
					"options": {
						"include": {
							"pattern": "^(instance|Value #Succeeded|Value #Failed)$"
						}
					}
				},
				{
					"id": "organize",
					"options": {
						"renameByName": {
							"Value #Failed": "Failed",
							"Value #Succeeded": "Succeeded",
							"instance": "Host"
						}
					}
				},
				{
					"id": "calculateField",
					"options": {
						"alias": "Total",
						"binary": {
							"left": "Succeeded",
							"operator": "+",
							"right": "Failed"
						},
						"mode": "binary"
					}
				},
				{
					"id": "calculateField",
					"options": {
						"alias": "Success Rate",
						"binary": {
							"left": "Succeeded",
							"operator": "/",
							"right": "Total"
						},
						"mode": "binary"
					}
				},
				{
					"id": "organize",
					"options": {
						"excludeByName": {
							"Total": true
						},
						"indexByName": {
							"Failed": 2,
							"Host": 0,
							"Succeeded": 1,
							"Success Rate": 3
						}
					}
				}
			],
