"users.users.${cfg.user} = {\n"
"  uid = cfg.uid;\n"
"  gid = cfg.gid;\n"
"  isHidden = true;\n"
"  description = \"Forgejo Actions runner\";\n"
"};\n"
"users.groups.${cfg.group}.gid = cfg.gid;\n"
"users.knownUsers = [ cfg.user ];\n"
"users.knownGroups = [ cfg.group ];"
msgstr ""

#. type: heading *****
#: modules/configuration.org:2195
#, fuzzy, no-wrap
#| msgid "Starship"
msgid "State ownership"
msgstr "Starship"

#. type: paragraph
#: modules/configuration.org:2197
msgid ""
"Each state directory must exist and belong to the runner user before its "
"daemon starts. With =createHome= off nothing else creates it, so activation "
"makes and chowns it =mkBefore= the launchd step that loads the daemons."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2201
#, no-wrap
msgid "forgejo-runner-ownership"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2203
#, no-wrap
