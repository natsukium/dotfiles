#. type: heading *****
#: modules/configuration.org:2101
#, no-wrap
msgid "Launchd daemons"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2103
msgid ""
"One launchd job per enabled instance. launchd has no =EnvironmentFile=, so a "
"=tokenFile= instance sources it in-script while an inline =token= rides on "
"=EnvironmentVariables=; either way the script sees =$TOKEN=. I prepend "
"=coreutils= to =PATH= so the script's own =sha256sum=/=cut= resolve even if "
"a host trims =hostPackages=. Two launchd quirks shape each:"
msgstr ""

#. type: plain list -
#: modules/configuration.org:2112
#, no-wrap
msgid ""
"=WorkingDirectory= cannot be the state directory: launchd chdir()s into it\n"
"/before/ exec, so on first boot the spawn aborts with =EX_CONFIG= (78) before\n"
"the script can create it. The script sets its own cwd instead."
msgstr ""

#. type: plain list -
#: modules/configuration.org:2116
#, no-wrap
msgid ""
"The logs live in the user-owned state directory, not =/var/log=: launchd\n"
"opens them as =UserName=, and an unprivileged daemon cannot create a\n"
"root-owned file under =/var/log=, so it would fail to spawn — silently,\n"
"before any log line."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2117
#, no-wrap
msgid "forgejo-runner-daemons"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2119
#, no-wrap
msgid ""
"launchd.daemons = lib.mapAttrs' (\n"
"  _: instance:\n"
"  let\n"
"    configFile = settingsFormat.generate \"config.yaml\" instance.settings;\n"
"  in\n"
"  lib.nameValuePair \"forgejo-runner-${instance.name}\" {\n"
"    script = ''\n"
"      set -eu\n"
"      mkdir -p ${lib.escapeShellArg instance.stateDir}\n"
"      cd ${lib.escapeShellArg instance.stateDir}\n"
"      ${lib.optionalString (instance.tokenFile != null) ''\n"
"        set -a\n"
"        . ${lib.escapeShellArg (toString instance.tokenFile)}\n"
"        set +a\n"
"      ''}\n"
"      labels=${lib.escapeShellArg (lib.concatStringsSep \",\" instance.labels)}\n"
"      state=\"$(printf '%s' \"$TOKEN\" | sha256sum | cut -d' ' -f1) $labels\""
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2137
#, no-wrap
msgid ""
"if [ ! -f .runner ] || [ \"$(cat .registration-state 2>/dev/null)\" != \"$state\" ]; then\n"
"  rm -f .runner\n"
"  ${lib.getExe cfg.package} register \\\n"
"    --no-interactive \\\n"
"    --instance ${lib.escapeShellArg instance.url} \\\n"
"    --token \"$TOKEN\" \\\n"
"    --name ${lib.escapeShellArg instance.name} \\\n"
"    --labels \"$labels\" \\\n"
"    --config ${configFile}\n"
"  printf '%s' \"$state\" > .registration-state\n"
"fi"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2149
#, no-wrap
msgid ""
"      exec ${lib.getExe cfg.package} daemon --config ${configFile}\n"
"    '';\n"
"    serviceConfig = {\n"
"      UserName = cfg.user;\n"
"      GroupName = cfg.group;\n"
"      KeepAlive = true;\n"
"      RunAtLoad = true;\n"
"      ProcessType = \"Background\";\n"
"      EnvironmentVariables = {\n"
"        HOME = instance.stateDir;\n"
"        PATH = \"${\n"
"          lib.makeBinPath ([ pkgs.coreutils ] ++ instance.hostPackages)\n"
"        }:/usr/bin:/bin:/usr/sbin:/sbin\";\n"
"      }\n"
"      // lib.optionalAttrs (instance.token != null) { TOKEN = instance.token; };\n"
"      StandardOutPath = \"${instance.stateDir}/forgejo-runner.log\";\n"
"      StandardErrorPath = \"${instance.stateDir}/forgejo-runner.err.log\";\n"
"    };\n"
"  }\n"
") enabledInstances;"
msgstr ""

#. type: heading *****
#: modules/configuration.org:2171
#, no-wrap
msgid "Runner user"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2173
msgid ""
"nix-darwin only manages accounts listed in =users.knownUsers= / "
"=users.knownGroups=, so I add the entries."
msgstr ""

#. type: paragraph
#: modules/configuration.org:2176
msgid ""
"I leave =createHome= off: it runs =createhomedir=, which resolves the =/var= "
"firmlink and records the home as =/private/var/…=, then nix-darwin string-"
"compares that against the configured =home= and aborts activation on the "
"mismatch. The daemon uses its state directory as =HOME= anyway, created and "
"owned below."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2182
#, no-wrap
msgid "forgejo-runner-user"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2184
#, no-wrap
