#, no-wrap
msgid ""
"  perSystem =\n"
"    { pkgs, ... }:\n"
"    {\n"
"      packages.emacs = mkEmacs pkgs;\n"
"    };\n"
"}"
msgstr ""

#. type: paragraph in src
