#. type: heading **
#: modules/configuration.org:3030
#, no-wrap
msgid "Spotlight"
msgstr ""

#. type: paragraph
#: modules/configuration.org:3032
msgid ""
"I don't use Spotlight search, yet its indexer (=mdworker=) keeps consuming "
"CPU, disk I/O, and disk space in the background, so I turn indexing off by "
"default. Hosts that want it back can set =enableIndex = true=. nix-darwin "
"has no option for this, so the module drives =mdutil= from an activation "
"script."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3043
#, no-wrap
msgid ""
"{ ... }:\n"
"{\n"
"  flake.modules.darwin.spotlight =\n"
"    { config, lib, ... }:\n"
"    let\n"
"      cfg = config.my.services.spotlight;\n"
"    in\n"
"    {\n"
"      <<spotlight-options>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3053
#, no-wrap
msgid ""
"      <<spotlight-config>>\n"
"    };\n"
"}"
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:3060
#, no-wrap
msgid "spotlight-options"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3062
#, no-wrap
msgid ""
"options.my.services.spotlight = {\n"
"  enableIndex = lib.mkOption {\n"
"    type = lib.types.bool;\n"
"    default = false;\n"
"    description = \"Whether Spotlight indexes the volumes on this machine.\";\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph
#: modules/configuration.org:3073
msgid ""
"=mdutil= targets all volumes with =-a= rather than just =/=: modern macOS "
"splits the boot disk into a read-only System volume (=/=) and a writable "
"Data volume, so =mdutil -i off /= silently leaves the Data volume indexing. "
"When disabling, =mdutil -E= also erases the orphaned index stores to reclaim "
"disk space."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:3078
#, no-wrap
msgid "spotlight-config"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3080
#, no-wrap
msgid ""
"config = {\n"
"  system.activationScripts.extraActivation.text =\n"
"    if cfg.enableIndex then\n"
"      ''\n"
"        echo \"enabling spotlight indexing...\"\n"
"        mdutil -i on -a &> /dev/null\n"
"      ''\n"
"    else\n"
"      ''\n"
"        echo \"disabling spotlight indexing...\"\n"
"        mdutil -i off -d -a &> /dev/null\n"
"        mdutil -E -a &> /dev/null\n"
"      '';\n"
"};"
msgstr ""

