#. type: heading ***
#: modules/configuration.org:2600
#, no-wrap
msgid "Extensions"
msgstr "拡張機能"

#. type: paragraph
#: modules/configuration.org:2602
msgid ""
"Browser extensions managed declaratively. Extensions are sourced from two "
"overlay-provided sets: =firefox-addons= (from the NUR firefox-addons "
"repository) and =my-firefox-addons= (custom additions not available "
"upstream)."
msgstr ""
"宣言的に管理されるブラウザ拡張機能です。拡張機能は2つのoverlayで提供される"
"セットから取得されます。=firefox-addons=（NUR firefox-addonsリポジトリから）"
"と =my-firefox-addons=（アップストリームにないカスタムの追加）です。"

#. type: keyword NAME
#: modules/configuration.org:2606
#, no-wrap
msgid "zen-browser-extensions"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2608
#, no-wrap
msgid ""
"extensions = {\n"
"  packages =\n"
"    (with pkgs.firefox-addons; [\n"
"      bitwarden\n"
"      instapaper-official\n"
"      keepa\n"
"      onepassword-password-manager\n"
"      refined-github\n"
"      vimium\n"
"      violentmonkey\n"
"      wayback-machine\n"
"      zotero-connector\n"
"    ])\n"
"    ++ (with pkgs.my-firefox-addons; [\n"
"      adguard-adblocker\n"
"      calilay\n"
"      kiseppe-price-chart-kindle\n"
"    ]);\n"
"};"
msgstr ""

#. type: heading **
#: modules/configuration.org:2631
#, no-wrap
msgid "Neovim"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2633
msgid ""
"Neovim is the editor I spend the most time in, primarily for coding — though "
"the gravitational pull of =org-mode= is slowly dragging me over to Emacs."
msgstr ""

#. type: paragraph
#: modules/configuration.org:2637
msgid ""
"Everything Neovim-related lives under =features/neovim/=: the wrapped "
"derivation (=package.nix=) and the lua configuration. The flake-parts module "
"pulls double duty from a single file:"
msgstr ""

#. type: plain list 1.
#: modules/configuration.org:2643
#, no-wrap
msgid ""
"=perSystem.packages.neovim= makes =nix run .#neovim= work on every\n"
"supported system."
msgstr ""

#. type: plain list 2.
#: modules/configuration.org:2648
#, no-wrap
msgid ""
"=flake.modules.homeManager.neovim= registers the module in the\n"
"internal registry — not the public =homeManagerModules= export, since\n"
"the =my.*= options make it opinionated — and lets a home-manager config\n"
"opt in with =my.programs.neovim.enable=, which installs the wrapped\n"
"Neovim plus =neovim-remote= and exports =EDITOR=nvim=."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2650
#, no-wrap
msgid ""
"{ ... }:\n"
"{\n"
"  flake.modules.homeManager.neovim =\n"
"    {\n"
"      config,\n"
"      lib,\n"
"      pkgs,\n"
"      ...\n"
"    }:\n"
"    {\n"
"      options.my.programs.neovim.enable = lib.mkEnableOption \"neovim\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2662
#, no-wrap
msgid ""
"  config = lib.mkIf config.my.programs.neovim.enable {\n"
"    home.packages = [\n"
"      (pkgs.callPackage ./package.nix { })\n"
"      pkgs.neovim-remote\n"
"    ];\n"
"    home.sessionVariables.EDITOR = \"nvim\";\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2671
#, no-wrap
msgid ""
"  perSystem =\n"
"    { pkgs, ... }:\n"
"    {\n"
"      packages.neovim = pkgs.callPackage ./package.nix { };\n"
"    };\n"
"}"
msgstr ""

#. type: heading **
#: modules/configuration.org:2679
#, no-wrap
msgid "Emacs"
msgstr "Emacs"

#. type: paragraph
#: modules/configuration.org:2681
msgid ""
"Emacs has been my second-most-used editor since early 2026. The draw is =org-"
"mode= — the workflows built around =org-capture= and =org-agenda= are slowly "
"winning me over, and a widening set of daily inputs (email, RSS feeds, and "
"more) now lives inside emacs, where the ongoing experiment is wiring each of "
"them back into org."
msgstr ""

#. type: paragraph
#: modules/configuration.org:2687
msgid ""
"The feature lives alongside Neovim under =features/emacs/= and pulls the "
"same double duty:"
msgstr ""

#. type: plain list 1.
#: modules/configuration.org:2694
#, no-wrap
msgid ""
"=perSystem.packages.emacs= exposes a wrapped emacs as a flake\n"
"output. =init.org= is pre-tangled into =default.el= and passed to\n"
"=emacsWithPackagesFromUsePackage= so =nix run .#emacs= loads the\n"
"full config without home-manager."
msgstr ""

#. type: plain list 2.
#: modules/configuration.org:2700
#, no-wrap
msgid ""
"=flake.modules.homeManager.emacs= registers the module in the internal\n"
"registry — not the public =homeManagerModules= export, since the =my.*=\n"
"options make it opinionated — and adds =my.programs.emacs.enable= for\n"
"home-manager hosts, wiring up =services.emacs= (daemon), the tangled\n"
"=~/.config/emacs/{init,early-init}.el=, and the encrypted\n"
"=~/.authinfo.age=."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2703
#, no-wrap
msgid ""
"{ lib, inputs, ... }:\n"
"let\n"
"  withEmacsOverlay = pkgs: pkgs.extend inputs.emacs-overlay.overlays.default;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2707
#, no-wrap
msgid ""
"emacsUnwrapped =\n"
"  pkgs:\n"
"  let\n"
"    epkgs = withEmacsOverlay pkgs;\n"
"  in\n"
"  if pkgs.stdenv.hostPlatform.isDarwin then epkgs.emacs-plus else epkgs.emacs-pgtk;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2717
#, no-wrap
msgid ""
"tangle =\n"
"  pkgs:\n"
"  {\n"
"    name,\n"
"    org,\n"
"  }:\n"
"  pkgs.runCommand name { nativeBuildInputs = [ (emacsUnwrapped pkgs) ]; } ''\n"
"    cp ${org} tmp.org\n"
"    emacs -Q --batch --eval \\\n"
"      \"(progn\n"
"        (require 'ob-tangle)\n"
"        (org-babel-tangle-file \\\"tmp.org\\\" \\\"emacs-lisp\\\"))\"\n"
"    install emacs-lisp $out\n"
"  '';"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2732
#, no-wrap
msgid ""
"tangleEl =\n"
"  pkgs: org:\n"
"  let\n"
"    stem = name: lib.head (lib.splitString \".\" name);\n"
"  in\n"
"  tangle pkgs {\n"
"    name = \"${stem (baseNameOf (toString org))}.el\";\n"
"    inherit org;\n"
"  };"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2742
#, no-wrap
msgid ""
"  mkEmacs =\n"
"    pkgs:\n"
"    (withEmacsOverlay pkgs).callPackage ./package.nix {\n"
"      defaultInitFile = tangle pkgs {\n"
"        name = \"default.el\";\n"
"        org = ./init.org;\n"
"      };\n"
"      org-clickup-src = inputs.org-clickup;\n"
"    };\n"
"in\n"
"{\n"
"  flake.modules.homeManager.emacs =\n"
"    {\n"
"      config,\n"
"      lib,\n"
"      pkgs,\n"
"      ...\n"
"    }:\n"
"    {\n"
"      options.my.programs.emacs.enable = lib.mkEnableOption \"emacs\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2763
#, no-wrap
msgid ""
"config = lib.mkIf config.my.programs.emacs.enable {\n"
"  programs.emacs = {\n"
"    enable = true;\n"
"    package = mkEmacs pkgs;\n"
"  };"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2769
#, no-wrap
msgid ""
"services.emacs = {\n"
"  enable = true;\n"
"  client.enable = true;\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2774
#, no-wrap
msgid ""
"xdg.configFile.\"emacs/init.el\".source = tangleEl pkgs ./init.org;\n"
"xdg.configFile.\"emacs/early-init.el\".source = tangleEl pkgs ./early-init.org;\n"
"home.file.\".authinfo.age\".source = ./authinfo.age;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2778
#, no-wrap
msgid ""
"    home.shellAliases = lib.optionalAttrs pkgs.stdenv.hostPlatform.isDarwin {\n"
