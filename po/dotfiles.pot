#. type: paragraph
#: configuration.org:1419
msgid ""
"The two pre-commit hook scripts share a common pattern: run a command, then "
"check =git diff= for changes and fail with instructions if any are "
"found. This shared logic lives in =check-git-changes.sh=."
msgstr ""

#. type: paragraph in src
#: configuration.org:1426 configuration.org:1445 configuration.org:1452
#, no-wrap
msgid "set -euo pipefail"
msgstr ""

#. type: paragraph in src
#: configuration.org:1428
#, no-wrap
msgid ""
"message=\"$1\"\n"
"shift"
msgstr ""

#. type: paragraph in src
#: configuration.org:1431
#, no-wrap
msgid "changed=$(git diff --name-only \"$@\")"
msgstr ""

#. type: paragraph in src
#: configuration.org:1433
#, no-wrap
msgid ""
"if [ -n \"$changed\" ]; then\n"
"  echo \"$message\"\n"
"  echo \"Changed files:\"\n"
"  echo \"$changed\"\n"
"  echo \"\"\n"
"  echo \"Please stage the changes and commit again:\"\n"
"  echo \"  git add $changed\"\n"
"  exit 1\n"
"fi"
msgstr ""

#. type: paragraph in src
#: configuration.org:1447
#, no-wrap
msgid ""
"po4a po4a.cfg\n"
"check-git-changes \"po4a updated translation files.\" -- po/ '*.ja.org'"
msgstr ""

#. type: paragraph in src
#: configuration.org:1454
#, no-wrap
msgid ""
"make -B tangle -j\n"
"check-git-changes \"Org files were out of sync and have been auto-tangled.\""
msgstr ""

#. type: paragraph in src
#: configuration.org:1459
#, no-wrap
msgid ""
