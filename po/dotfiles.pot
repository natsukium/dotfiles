"          packages = with pkgs; [\n"
"            aws-vault\n"
"            nix-fast-build\n"
"            sops\n"
"            ssh-to-age\n"
"            terraform'\n"
"            <<translation-packages>>\n"
"          ];\n"
"          shellHook =\n"
"            config.pre-commit.installationScript\n"
"            + config.mcp-servers.shellHook\n"
"            + ''\n"
"              echo \"Syncing CLAUDE.md...\"\n"
"              make CLAUDE.md >/dev/null 2>&1 || echo \"Warning: Failed to "
"generate CLAUDE.md\"\n"
"            '';\n"
"        };"
msgstr ""

#. type: paragraph in src
