#. type: heading *
#: modules/configuration.org:1922
#, no-wrap
msgid "Continuous Integration"
msgstr ""

#. type: heading **
#: modules/configuration.org:1924
#, no-wrap
msgid "Forgejo Actions Runner"
msgstr ""

#. type: paragraph
#: modules/configuration.org:1926
msgid ""
"My Forgejo instance dispatches Actions jobs to registered runners. Linux "
"hosts use nixpkgs' =services.gitea-actions-runner=; macOS has no such "
"module, so I add =services.forgejo-runner= for Darwin, driven by launchd and "
"shaped like the NixOS option so a runner reads the same on either platform."
msgstr ""

#. type: paragraph
#: modules/configuration.org:1931
msgid ""
"I split this into three modules. The nix-darwin mechanism is neutral, so I "
"publish it as =flake.darwinModules.forgejo-runner= via "
"[[file:exports.nix][exports.nix]]. The =my.services.forgejo-runner= wrappers "
"bake my defaults (instance URL, labels, niks3 client) and live in the "
"internal =flake.modules.{darwin,nixos}= registry.  A host enables a wrapper "
"and supplies its own registration token."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1943
#, no-wrap
msgid ""
"{ ... }:\n"
"let\n"
"  <<forgejo-runner-wrapper-shared>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1947
#, no-wrap
msgid ""
"  <<forgejo-runner-wrappers>>\n"
"in\n"
"{\n"
"  flake.modules.darwin.forgejo-runner = darwinWrapper;\n"
"  flake.modules.nixos.forgejo-runner = nixosWrapper;\n"
"}"
msgstr ""

#. type: heading ***
#: modules/configuration.org:1955
#, no-wrap
msgid "nix-darwin module"
msgstr ""

#. type: paragraph
#: modules/configuration.org:1957
msgid ""
"This module carries nothing personal — just =services.forgejo-runner=, "
"mirroring the instance schema of nixpkgs' =services.gitea-actions-runner= "
"(=token=/=tokenFile=, =labels=, freeform =settings=). Each enabled instance "
"becomes a launchd job that registers, then execs the daemon. I record a hash "
"of =token= plus =labels= in =.registration-state= so registration re-runs "
"when either changes; the token is reusable, so re-registering is fine."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1970
#, no-wrap
msgid ""
"{\n"
"  config,\n"
"  lib,\n"
"  pkgs,\n"
"  ...\n"
"}:\n"
"let\n"
"  cfg = config.services.forgejo-runner;\n"
"  settingsFormat = pkgs.formats.yaml { };"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1980
#, no-wrap
msgid "<<forgejo-runner-instance-submodule>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1982
#, no-wrap
msgid ""
"  enabledInstances = lib.filterAttrs (_: i: i.enable) cfg.instances;\n"
"in\n"
"{\n"
"  <<forgejo-runner-darwin-options>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1987
#, no-wrap
msgid ""
"  <<forgejo-runner-darwin-config>>\n"
"}"
msgstr ""

#. type: heading ****
#: modules/configuration.org:1991
#, no-wrap
msgid "Instance options"
msgstr ""

#. type: paragraph
#: modules/configuration.org:1993
msgid ""
"An instance carries its registration details and the tools its jobs need on "
"=PATH=. Exactly one of =token= or =tokenFile= supplies the token, matching "
"the NixOS module. Host-executed jobs inherit only the daemon's environment, "
"so every tool a workflow expects must be listed in =hostPackages=."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:1998
#, no-wrap
msgid "forgejo-runner-instance-submodule"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2000
#, no-wrap
msgid ""
"instanceModule =\n"
"  { name, ... }:\n"
"  {\n"
"    options = {\n"
"      enable = lib.mkEnableOption \"this runner instance\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2006
#, no-wrap
msgid ""
"name = lib.mkOption {\n"
"  type = lib.types.str;\n"
"  default = name;\n"
"  defaultText = lib.literalExpression \"the attribute name\";\n"
"  description = \"Name the runner registers under.\";\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2013
#, no-wrap
msgid ""
"url = lib.mkOption {\n"
"  type = lib.types.str;\n"
"  example = \"https://git.example.com\";\n"
"  description = \"Address of the Forgejo instance the runner registers "
"with.\";\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2019
#, no-wrap
msgid ""
"token = lib.mkOption {\n"
"  type = lib.types.nullOr lib.types.str;\n"
"  default = null;\n"
"  description = ''\n"
"    Registration token as a plaintext string. Mutually exclusive with\n"
"    {option}`tokenFile`. Prefer {option}`tokenFile`: a token set here ends\n"
"    up in the world-readable launchd plist and the Nix store.\n"
"  '';\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2029
#, no-wrap
msgid ""
"tokenFile = lib.mkOption {\n"
"  type = lib.types.nullOr (lib.types.either lib.types.str lib.types.path);\n"
"  default = null;\n"
"  description = ''\n"
"    Path to an environment file holding the registration token as\n"
"    `TOKEN=...`. Mutually exclusive with {option}`token`. The token is "
"read\n"
"    on first registration and whenever it or {option}`labels` change;\n"
"    otherwise the persisted {file}`.runner` credential in "
"{option}`stateDir`\n"
"    is used.\n"
"  '';\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2041
#, no-wrap
msgid ""
"labels = lib.mkOption {\n"
"  type = lib.types.listOf lib.types.str;\n"
"  example = [ \"macos:host\" ];\n"
"  description = \"Labels the runner advertises.\";\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2047
#, no-wrap
msgid ""
"settings = lib.mkOption {\n"
"  type = settingsFormat.type;\n"
"  default = { };\n"
"  description = ''\n"
"    Runner configuration written to {file}`config.yaml` and passed to the\n"
"    daemon with `--config`.\n"
"  '';\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2056
#, no-wrap
msgid ""
"hostPackages = lib.mkOption {\n"
"  type = lib.types.listOf lib.types.package;\n"
"  default = with pkgs; [\n"
"    bash\n"
"    coreutils\n"
"    curl\n"
"    gawk\n"
"    gitMinimal\n"
"    gnused\n"
"    nodejs\n"
"    wget\n"
"  ];\n"
"  defaultText = lib.literalExpression ''\n"
"    with pkgs; [ bash coreutils curl gawk gitMinimal gnused nodejs wget ]\n"
"  '';\n"
"  description = ''\n"
"    Packages put on PATH for host-executed jobs. Host jobs inherit only\n"
"    the daemon's PATH, so every tool a workflow expects must be listed.\n"
"  '';\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2077
#, no-wrap
msgid ""
"    stateDir = lib.mkOption {\n"
"      type = lib.types.str;\n"
"      default = \"/var/lib/forgejo-runner/${name}\";\n"
"      defaultText = lib.literalExpression "
"''\"/var/lib/forgejo-runner/<name>\"'';\n"
"      description = \"Directory holding the runner credential and working "
"files.\";\n"
"    };\n"
"  };\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:2087
#, no-wrap
msgid "Module options"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2089
msgid ""
"The daemons run as a dedicated unprivileged user, not root: a root daemon is "
"a trusted-user client of the nix daemon, whose post-build-hook push path the "
"multi-user daemon ignores — so nothing reaches my binary cache. An untrusted "
"user takes the store-scan push path that actually uploads. I may revisit "
"making it a trusted user once the post-build-hook path works for me."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2095
#, no-wrap
msgid "forgejo-runner-darwin-options"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2097
#, no-wrap
msgid ""
"options.services.forgejo-runner = {\n"
"  package = lib.mkPackageOption pkgs \"forgejo-runner\" { };"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2100
#, no-wrap
msgid ""
"user = lib.mkOption {\n"
"  type = lib.types.str;\n"
"  default = \"_forgejo-runner\";\n"
"  description = \"Dedicated unprivileged user the runner daemons execute "
"as.\";\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2106
#, no-wrap
msgid ""
"group = lib.mkOption {\n"
"  type = lib.types.str;\n"
"  default = \"_forgejo-runner\";\n"
"  description = \"Primary group for the runner user.\";\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2112
#, no-wrap
msgid ""
"uid = lib.mkOption {\n"
"  type = lib.types.int;\n"
"  default = 530;\n"
"  description = \"UID for the runner user (free system-range id on the "
"host).\";\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2118
#, no-wrap
msgid ""
"gid = lib.mkOption {\n"
"  type = lib.types.int;\n"
"  default = 530;\n"
"  description = \"GID for the runner group.\";\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2124
#, no-wrap
msgid ""
"  instances = lib.mkOption {\n"
"    type = lib.types.attrsOf (lib.types.submodule instanceModule);\n"
"    default = { };\n"
"    description = \"Runner instances; each enabled one becomes a launchd "
"daemon.\";\n"
"  };\n"
"};"
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2134
#, no-wrap
msgid "forgejo-runner-darwin-config"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2136
#, no-wrap
msgid ""
"config = lib.mkIf (enabledInstances != { }) {\n"
"  assertions = lib.mapAttrsToList (_: instance: {\n"
"    assertion = (instance.token == null) != (instance.tokenFile == null);\n"
"    message = \"services.forgejo-runner.instances.${instance.name}: set "
"exactly one of token or tokenFile.\";\n"
"  }) enabledInstances;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2142
#, no-wrap
msgid "<<forgejo-runner-daemons>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2144
#, no-wrap
msgid "<<forgejo-runner-user>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2146
#, no-wrap
msgid ""
"  <<forgejo-runner-ownership>>\n"
"};"
msgstr ""

#. type: heading *****
#: modules/configuration.org:2150
#, no-wrap
msgid "Launchd daemons"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2152
msgid ""
"One launchd job per enabled instance. launchd has no =EnvironmentFile=, so a "
"=tokenFile= instance sources it in-script while an inline =token= rides on "
"=EnvironmentVariables=; either way the script sees =$TOKEN=. I prepend "
"=coreutils= to =PATH= so the script's own =sha256sum=/=cut= resolve even if "
"a host trims =hostPackages=. Two launchd quirks shape each:"
msgstr ""

#. type: plain list -
#: modules/configuration.org:2161
#, no-wrap
msgid ""
"=WorkingDirectory= cannot be the state directory: launchd chdir()s into it\n"
"/before/ exec, so on first boot the spawn aborts with =EX_CONFIG= (78) "
"before\n"
"the script can create it. The script sets its own cwd instead."
msgstr ""

#. type: plain list -
#: modules/configuration.org:2165
#, no-wrap
msgid ""
"The logs live in the user-owned state directory, not =/var/log=: launchd\n"
"opens them as =UserName=, and an unprivileged daemon cannot create a\n"
"root-owned file under =/var/log=, so it would fail to spawn — silently,\n"
"before any log line."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2166
#, no-wrap
msgid "forgejo-runner-daemons"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2168
#, no-wrap
msgid ""
"launchd.daemons = lib.mapAttrs' (\n"
"  _: instance:\n"
"  let\n"
"    configFile = settingsFormat.generate \"config.yaml\" "
"instance.settings;\n"
"  in\n"
"  lib.nameValuePair \"forgejo-runner-${instance.name}\" {\n"
"    script = ''\n"
"      set -eu\n"
"      mkdir -p ${lib.escapeShellArg instance.stateDir}\n"
"      cd ${lib.escapeShellArg instance.stateDir}\n"
"      ${lib.optionalString (instance.tokenFile != null) ''\n"
"        set -a\n"
"        . ${lib.escapeShellArg (toString instance.tokenFile)}\n"
"        set +a\n"
"      ''}\n"
"      labels=${lib.escapeShellArg (lib.concatStringsSep \",\" "
"instance.labels)}\n"
"      state=\"$(printf '%s' \"$TOKEN\" | sha256sum | cut -d' ' -f1) "
"$labels\""
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2186
#, no-wrap
msgid ""
"if [ ! -f .runner ] || [ \"$(cat .registration-state 2>/dev/null)\" != "
"\"$state\" ]; then\n"
"  rm -f .runner\n"
"  ${lib.getExe cfg.package} register \\\n"
"    --no-interactive \\\n"
"    --instance ${lib.escapeShellArg instance.url} \\\n"
"    --token \"$TOKEN\" \\\n"
"    --name ${lib.escapeShellArg instance.name} \\\n"
"    --labels \"$labels\" \\\n"
"    --config ${configFile}\n"
"  printf '%s' \"$state\" > .registration-state\n"
"fi"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2198
#, no-wrap
msgid ""
"      exec ${lib.getExe cfg.package} daemon --config ${configFile}\n"
"    '';\n"
"    serviceConfig = {\n"
"      UserName = cfg.user;\n"
"      GroupName = cfg.group;\n"
"      KeepAlive = true;\n"
"      RunAtLoad = true;\n"
"      ProcessType = \"Background\";\n"
"      EnvironmentVariables = {\n"
"        HOME = instance.stateDir;\n"
"        PATH = \"${\n"
"          lib.makeBinPath ([ pkgs.coreutils ] ++ instance.hostPackages)\n"
"        }:/usr/bin:/bin:/usr/sbin:/sbin\";\n"
"      }\n"
"      // lib.optionalAttrs (instance.token != null) { TOKEN = "
"instance.token; };\n"
"      StandardOutPath = \"${instance.stateDir}/forgejo-runner.log\";\n"
"      StandardErrorPath = \"${instance.stateDir}/forgejo-runner.err.log\";\n"
"    };\n"
"  }\n"
") enabledInstances;"
msgstr ""

#. type: heading *****
#: modules/configuration.org:2220
#, no-wrap
msgid "Runner user"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2222
msgid ""
"nix-darwin only manages accounts listed in =users.knownUsers= / "
"=users.knownGroups=, so I add the entries."
msgstr ""

#. type: paragraph
#: modules/configuration.org:2225
msgid ""
"I leave =createHome= off: it runs =createhomedir=, which resolves the =/var= "
"firmlink and records the home as =/private/var/…=, then nix-darwin "
"string-compares that against the configured =home= and aborts activation on "
"the mismatch. The daemon uses its state directory as =HOME= anyway, created "
"and owned below."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2231
#, no-wrap
msgid "forgejo-runner-user"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2233
#, no-wrap
msgid ""
"users.users.${cfg.user} = {\n"
"  uid = cfg.uid;\n"
"  gid = cfg.gid;\n"
"  isHidden = true;\n"
"  description = \"Forgejo Actions runner\";\n"
"};\n"
"users.groups.${cfg.group}.gid = cfg.gid;\n"
"users.knownUsers = [ cfg.user ];\n"
"users.knownGroups = [ cfg.group ];"
msgstr ""

#. type: heading *****
#: modules/configuration.org:2244
#, no-wrap
msgid "State ownership"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2246
msgid ""
"Each state directory must exist and belong to the runner user before its "
"daemon starts. With =createHome= off nothing else creates it, so activation "
"makes and chowns it =mkBefore= the launchd step that loads the daemons."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2250
#, no-wrap
msgid "forgejo-runner-ownership"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2252
#, no-wrap
msgid ""
"system.activationScripts.launchd.text = lib.mkBefore (\n"
"  lib.concatMapStringsSep \"\\n\" (instance: ''\n"
"    mkdir -p ${lib.escapeShellArg instance.stateDir}\n"
"    chown -R ${lib.escapeShellArg cfg.user}:${lib.escapeShellArg cfg.group} "
"${lib.escapeShellArg instance.stateDir}\n"
"  '') (lib.attrValues enabledInstances)\n"
");"
msgstr ""

#. type: heading ***
#: modules/configuration.org:2260
#, no-wrap
msgid "Opinionated wrappers"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2262
msgid ""
"The two platforms drive different options — =services.forgejo-runner= on "
"Darwin, =services.gitea-actions-runner= on NixOS — but since the nix-darwin "
"module mirrors the NixOS instance schema, the wrappers share one option "
"surface and one =mkInstance= builder. My =my.services.forgejo-runner= "
"options give =enable=, =url= (defaulting to my Forgejo instance), =labels=, "
"and a =tokenFile= path; the host owns the secret and hands only its "
"path. Each wrapper holds only the per-platform deltas: the =labels= default, "
"=hostPackages=, and — on NixOS — the package and Docker for container "
"jobs. Both push to my binary cache, so each =hostPackages= adds =nix= and "
"the niks3 client."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2272
#, no-wrap
msgid "forgejo-runner-wrapper-shared"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2274
#, no-wrap
msgid ""
"wrapperOptions =\n"
"  { lib, ... }:\n"
"  {\n"
"    options.my.services.forgejo-runner = {\n"
"      enable = lib.mkEnableOption \"Forgejo Actions runner\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2280
#, no-wrap
msgid ""
"url = lib.mkOption {\n"
"  type = lib.types.str;\n"
"  default = \"https://git.natsukium.com\";\n"
"  description = \"Forgejo instance the runner registers with.\";\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2286
#, no-wrap
msgid ""
"tokenFile = lib.mkOption {\n"
"  type = lib.types.path;\n"
"  description = ''\n"
"    Path to an environment file holding the registration token as\n"
"    `TOKEN=...`. The host supplies this — typically a secret-manager path "
"—\n"
"    so the feature stays free of any secret-store assumption.\n"
"  '';\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2295
#, no-wrap
msgid ""
"    labels = lib.mkOption {\n"
"      type = lib.types.listOf lib.types.str;\n"
"      description = \"Labels the runner advertises; each platform sets a "
"default.\";\n"
"    };\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2302
#, no-wrap
msgid ""
"mkInstance = config: hostPackages: {\n"
"  enable = true;\n"
"  name = config.networking.hostName;\n"
"  url = config.my.services.forgejo-runner.url;\n"
"  tokenFile = config.my.services.forgejo-runner.tokenFile;\n"
"  labels = config.my.services.forgejo-runner.labels;\n"
"  inherit hostPackages;\n"
"};"
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2312
#, no-wrap
msgid "forgejo-runner-wrappers"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2314
#, no-wrap
msgid ""
"darwinWrapper =\n"
"  {\n"
"    config,\n"
"    lib,\n"
"    pkgs,\n"
"    inputs,\n"
"    ...\n"
"  }:\n"
"  {\n"
"    imports = [\n"
"      ./darwin-module.nix\n"
"      wrapperOptions\n"
"    ];"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2328
#, no-wrap
msgid ""
"config = lib.mkIf config.my.services.forgejo-runner.enable {\n"
"  my.services.forgejo-runner.labels = lib.mkDefault [\n"
"    \"macos:host\"\n"
"    \"macos-aarch64:host\"\n"
"  ];"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2334
#, no-wrap
msgid ""
"    services.forgejo-runner.instances.default = mkInstance config (\n"
"      with pkgs;\n"
"      [\n"
"        bash\n"
"        curl\n"
"        git\n"
"        nix\n"
"        nodejs\n"
"        toybox\n"
"        inputs.niks3.packages.${pkgs.stdenv.hostPlatform.system}.niks3\n"
"      ]\n"
"    );\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2349
#, no-wrap
msgid ""
"nixosWrapper =\n"
"  {\n"
"    config,\n"
"    lib,\n"
"    pkgs,\n"
"    inputs,\n"
"    ...\n"
"  }:\n"
"  {\n"
"    imports = [ wrapperOptions ];"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2360
#, no-wrap
msgid ""
"config = lib.mkIf config.my.services.forgejo-runner.enable {\n"
"  my.services.forgejo-runner.labels = lib.mkDefault [\n"
"    \"ubuntu-latest:docker://node:22-bookworm\"\n"
"    \"nix:host\"\n"
"  ];"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2366
#, no-wrap
msgid ""
"services.gitea-actions-runner = {\n"
"  package = pkgs.forgejo-runner;\n"
"  instances.default = mkInstance config (\n"
"    with pkgs;\n"
"    [\n"
"      bash\n"
"      busybox\n"
"      curl\n"
"      git\n"
"      nix\n"
"      nodejs\n"
"      inputs.niks3.packages.${pkgs.stdenv.hostPlatform.system}.niks3\n"
"    ]\n"
"  );\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2382
#, no-wrap
msgid ""
"    virtualisation.docker.enable = true;\n"
"  };\n"
"};"
msgstr ""

#. type: heading *
#: modules/configuration.org:2387
#, no-wrap
msgid "Devices"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2389
msgid ""
"Peripherals that move between machines belong here, not in "
"=hardware-configuration=, which describes a host's fixed internals. Each "
"device is a switch under =my.devices.*=, exposed through the "
"=flake.modules.nixos.devices= registry; a host enables only the ones it has "
"plugged in."
msgstr ""

#. type: heading **
#: modules/configuration.org:2395
#, no-wrap
msgid "Audio"
msgstr ""

#. type: heading ***
#: modules/configuration.org:2397
#, no-wrap
msgid "AT2040 microphone"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2399
msgid ""
"The AT2040 is a USB microphone that also exposes a headphone "
"output. WirePlumber gives that output a higher default priority (1109) than "
"the HDMI sink (1000), so plugging the mic in silently hijacks the default "
"output. I demote the AT2040 sink to the lowest priority so the host's "
"existing output stays selected; the =media.class= guard holds back the sink "
"alone, leaving the mic input at its own high priority to still become the "
"default source."
msgstr ""

#. type: paragraph
#: modules/configuration.org:2406
msgid ""
"The rule matches on =alsa.card_name= rather than the serial-bearing "
"=node.name=, so it survives re-plugging and would apply to a replacement "
"unit."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2415
#, no-wrap
msgid ""
"{ ... }:\n"
"{\n"
"  flake.modules.nixos.devices =\n"
"    {\n"
"      config,\n"
"      lib,\n"
"      ...\n"
"    }:\n"
"    let\n"
"      cfg = config.my.devices;\n"
"    in\n"
"    {\n"
"      options.my.devices.audio.at2040.enable =\n"
"        lib.mkEnableOption \"AT2040 USB mic sink demotion so it does not "
"steal the default output\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2431
#, no-wrap
msgid ""
"      config = lib.mkIf cfg.audio.at2040.enable {\n"
"        services.pipewire.wireplumber.extraConfig.\"51-at2040-demote-sink\" "
"= {\n"
"          \"monitor.alsa.rules\" = [\n"
"            {\n"
"              matches = [\n"
"                {\n"
"                  \"media.class\" = \"Audio/Sink\";\n"
"                  \"alsa.card_name\" = \"AT2040USB\";\n"
"                }\n"
"              ];\n"
"              actions.update-props = {\n"
"                \"priority.driver\" = 0;\n"
"                \"priority.session\" = 0;\n"
"              };\n"
"            }\n"
"          ];\n"
"        };\n"
"      };\n"
"    };\n"
"}"
msgstr ""

#. type: heading *
#: modules/configuration.org:2453
#, no-wrap
msgid "Browser"
msgstr ""

#. type: heading **
#: modules/configuration.org:2455
#, no-wrap
msgid "Zen Browser"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2457
msgid ""
"[[https://zen-browser.app/][Zen Browser]] is a Firefox-based browser with a "
"focus on privacy and customization.  Firefox derivatives were preferred over "
"Chromium-based browsers because Firefox's extension ecosystem and "
"=about:config= provide deeper control over browser behavior, and the Nix "
"ecosystem has mature tooling for managing Firefox profiles declaratively via "
"home-manager."
msgstr ""

#. type: paragraph
#: modules/configuration.org:2462
msgid ""
"Zen Browser was chosen over vanilla Firefox for its improved UI/UX while "
"retaining full Firefox compatibility — extensions, search engines, and "
"profile settings work identically."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2471
#, no-wrap
msgid ""
"{ ... }:\n"
"{\n"
"  flake.modules.homeManager.\"zen-browser\" =\n"
"    {\n"
"      inputs,\n"
"      config,\n"
"      lib,\n"
"      pkgs,\n"
"      ...\n"
"    }:\n"
"    let\n"
"      cfg = config.my.programs.zen-browser;\n"
"    in\n"
"    {\n"
"      imports = [ inputs.zen-browser.homeModules.beta ];"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2487
#, no-wrap
msgid ""
"options.my.programs.zen-browser = {\n"
"  enable = lib.mkEnableOption \"Zen Browser\";\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2491
#, no-wrap
msgid ""
"config = lib.mkIf cfg.enable {\n"
"  programs.zen-browser = {\n"
"    enable = true;\n"
"    profiles.natsukium = {\n"
"      <<zen-browser-settings>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2497
#, no-wrap
msgid "<<zen-browser-search>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2499
#, no-wrap
msgid ""
"            <<zen-browser-extensions>>\n"
"          };\n"
"        };\n"
"      };\n"
"    };\n"
"}"
msgstr ""

#. type: heading ***
#: modules/configuration.org:2507
#, no-wrap
msgid "Settings"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2509
msgid ""
"Auto-install extensions without user prompts. By default, Firefox shows a "
"confirmation dialog for each extension installed via the profile. Setting "
"=extensions.autoDisableScopes= to 0 disables this behavior, which is "
"necessary for fully declarative extension management — otherwise the first "
"launch after a profile rebuild would require manual approval for every "
"extension."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2515
#, no-wrap
msgid "zen-browser-settings"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2517
#, no-wrap
msgid ""
"settings = {\n"
"  \"extensions.autoDisableScopes\" = 0;\n"
"};"
msgstr ""

#. type: heading ***
#: modules/configuration.org:2522
#, no-wrap
msgid "Search Engines"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2524
msgid ""
"Custom search engines for quick access to development-related package "
"registries and documentation. Each engine is assigned a short alias (e.g., "
"=@np=) for use in the address bar, avoiding the need to navigate to each "
"site manually."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2528
#, no-wrap
msgid "zen-browser-search"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2530
#, no-wrap
msgid ""
"search = {\n"
"  force = true;\n"
"  engines = {\n"
"    <<zen-browser-search-engine-nix-packages>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2535
#, no-wrap
msgid "<<zen-browser-search-engine-nixos-wiki>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2537
#, no-wrap
msgid "<<zen-browser-search-engine-noogle>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2539
#, no-wrap
msgid "<<zen-browser-search-engine-crates-io>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2541
#, no-wrap
msgid "<<zen-browser-search-engine-npm>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2543
#, no-wrap
msgid ""
"    <<zen-browser-search-engine-pypi>>\n"
"  };\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:2548
#, no-wrap
msgid "Nix Packages"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2550
msgid ""
"Search the official NixOS/nixpkgs repository. Uses =nixos-icons= from "
"nixpkgs for the icon to avoid depending on an external URL that could change "
"or become unavailable."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2553
#, no-wrap
msgid "zen-browser-search-engine-nix-packages"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2555
#, no-wrap
msgid ""
"nix-packages = {\n"
"  name = \"Nix Packages\";\n"
"  urls = [\n"
"    {\n"
"      template = \"https://search.nixos.org/packages\";\n"
"      params = [\n"
"        {\n"
"          name = \"type\";\n"
"          value = \"packages\";\n"
"        }\n"
"        {\n"
"          name = \"query\";\n"
"          value = \"{searchTerms}\";\n"
"        }\n"
"      ];\n"
"    }\n"
"  ];"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2573
#, no-wrap
msgid ""
"  icon = "
"\"${pkgs.nixos-icons}/share/icons/hicolor/scalable/apps/nix-snowflake.svg\";\n"
"  definedAliases = [ \"@np\" ];\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:2578
#, no-wrap
msgid "NixOS Wiki"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2580
msgid ""
"Search the NixOS community wiki for configuration examples and "
"troubleshooting guides."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2582
#, no-wrap
msgid "zen-browser-search-engine-nixos-wiki"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2584
#, no-wrap
msgid ""
"nixos-wiki = {\n"
"  name = \"NixOS Wiki\";\n"
"  urls = [ { template = "
"\"https://wiki.nixos.org/w/index.php?search={searchTerms}\"; } ];\n"
"  icon = \"https://wiki.nixos.org/favicon.ico\";\n"
"  definedAliases = [ \"@nw\" ];\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:2592
#, no-wrap
msgid "noogle"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2594
msgid ""
"[[https://noogle.dev/][noogle]] is a Nix function search engine — the "
"equivalent of Hoogle for Haskell.  Useful for discovering library functions "
"by type signature or name when writing Nix expressions."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2597
#, no-wrap
msgid "zen-browser-search-engine-noogle"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2599
#, no-wrap
msgid ""
"noogle = {\n"
"  name = \"noogle\";\n"
"  urls = [ { template = \"https://noogle.dev/q?term={searchTerms}\"; } ];\n"
"  icon = \"https://noogle.dev/favicon.png\";\n"
"  definedAliases = [ \"@noogle\" ];\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:2607
#, no-wrap
msgid "crates.io"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2609
msgid ""
"Search the Rust package registry for crate discovery and version "
"information."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2611
#, no-wrap
msgid "zen-browser-search-engine-crates-io"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2613
#, no-wrap
msgid ""
"crates-io = {\n"
"  name = \"crates.io\";\n"
"  urls = [ { template = \"https://crates.io/search?q={searchTerms}\"; } ];\n"
"  icon = \"https://crates.io/favicon.ico\";\n"
"  definedAliases = [ \"@crates\" ];\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:2621
#, no-wrap
msgid "npm"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2623
msgid "Search the npm registry for JavaScript/TypeScript package discovery."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2625
#, no-wrap
msgid "zen-browser-search-engine-npm"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2627
#, no-wrap
msgid ""
"npm = {\n"
"  name = \"npm\";\n"
"  urls = [ { template = \"https://www.npmjs.com/search?q={searchTerms}\"; } "
"];\n"
"  icon = \"https://www.google.com/s2/favicons?domain=npmjs.com&sz=64\";\n"
"  definedAliases = [ \"@npm\" ];\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:2635
#, no-wrap
msgid "PyPI"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2637
msgid "Search the Python Package Index for Python package discovery."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2639
#, no-wrap
msgid "zen-browser-search-engine-pypi"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2641
#, no-wrap
msgid ""
"pypi = {\n"
"  name = \"PyPI\";\n"
"  urls = [ { template = \"https://pypi.org/search/?q={searchTerms}\"; } ];\n"
"  icon = \"https://pypi.org/favicon.ico\";\n"
"  definedAliases = [ \"@pypi\" ];\n"
"};"
msgstr ""

#. type: heading ***
#: modules/configuration.org:2649
#, no-wrap
msgid "Extensions"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2651
msgid ""
"Browser extensions managed declaratively. Extensions are sourced from two "
"overlay-provided sets: =firefox-addons= (from the NUR firefox-addons "
"repository) and =my-firefox-addons= (custom additions not available "
"upstream)."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:2655
#, no-wrap
msgid "zen-browser-extensions"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2657
#, no-wrap
msgid ""
"extensions = {\n"
"  packages =\n"
"    (with pkgs.firefox-addons; [\n"
"      bitwarden\n"
"      instapaper-official\n"
"      keepa\n"
"      onepassword-password-manager\n"
"      refined-github\n"
"      vimium\n"
"      violentmonkey\n"
"      wayback-machine\n"
"      zotero-connector\n"
"    ])\n"
"    ++ (with pkgs.my-firefox-addons; [\n"
"      adguard-adblocker\n"
"      calilay\n"
"      kiseppe-price-chart-kindle\n"
"    ]);\n"
"};"
msgstr ""

#. type: heading **
#: modules/configuration.org:2680
#, no-wrap
msgid "Neovim"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2682
msgid ""
"Neovim is the editor I spend the most time in, primarily for coding — though "
"the gravitational pull of =org-mode= is slowly dragging me over to Emacs."
msgstr ""

#. type: paragraph
#: modules/configuration.org:2686
msgid ""
"Everything Neovim-related lives under =features/neovim/=: the wrapped "
"derivation (=package.nix=) and the lua configuration. The flake-parts module "
"pulls double duty from a single file:"
msgstr ""

#. type: plain list 1.
#: modules/configuration.org:2692
#, no-wrap
msgid ""
"=perSystem.packages.neovim= makes =nix run .#neovim= work on every\n"
"supported system."
msgstr ""

#. type: plain list 2.
#: modules/configuration.org:2697
#, no-wrap
msgid ""
"=flake.modules.homeManager.neovim= registers the module in the\n"
"internal registry — not the public =homeManagerModules= export, since\n"
"the =my.*= options make it opinionated — and lets a home-manager config\n"
"opt in with =my.programs.neovim.enable=, which installs the wrapped\n"
"Neovim plus =neovim-remote= and exports =EDITOR=nvim=."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2699
#, no-wrap
msgid ""
"{ ... }:\n"
"{\n"
"  flake.modules.homeManager.neovim =\n"
"    {\n"
"      config,\n"
"      lib,\n"
"      pkgs,\n"
"      ...\n"
"    }:\n"
"    {\n"
"      options.my.programs.neovim.enable = lib.mkEnableOption \"neovim\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2711
#, no-wrap
msgid ""
"  config = lib.mkIf config.my.programs.neovim.enable {\n"
"    home.packages = [\n"
"      (pkgs.callPackage ./package.nix { })\n"
"      pkgs.neovim-remote\n"
"    ];\n"
"    home.sessionVariables.EDITOR = \"nvim\";\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2720
#, no-wrap
msgid ""
"  perSystem =\n"
"    { pkgs, ... }:\n"
"    {\n"
"      packages.neovim = pkgs.callPackage ./package.nix { };\n"
"    };\n"
"}"
msgstr ""

#. type: heading **
#: modules/configuration.org:2728
#, no-wrap
msgid "Emacs"
msgstr ""

#. type: paragraph
#: modules/configuration.org:2730
msgid ""
"Emacs has been my second-most-used editor since early 2026. The draw is "
"=org-mode= — the workflows built around =org-capture= and =org-agenda= are "
"slowly winning me over, and a widening set of daily inputs (email, RSS "
"feeds, and more) now lives inside emacs, where the ongoing experiment is "
"wiring each of them back into org."
msgstr ""

#. type: paragraph
#: modules/configuration.org:2736
msgid ""
"The feature lives alongside Neovim under =features/emacs/= and pulls the "
"same double duty:"
msgstr ""

#. type: plain list 1.
#: modules/configuration.org:2743
#, no-wrap
msgid ""
"=perSystem.packages.emacs= exposes a wrapped emacs as a flake\n"
"output. =init.org= is pre-tangled into =default.el= and passed to\n"
"=emacsWithPackagesFromUsePackage= so =nix run .#emacs= loads the\n"
"full config without home-manager."
msgstr ""

#. type: plain list 2.
#: modules/configuration.org:2749
#, no-wrap
msgid ""
"=flake.modules.homeManager.emacs= registers the module in the internal\n"
"registry — not the public =homeManagerModules= export, since the =my.*=\n"
"options make it opinionated — and adds =my.programs.emacs.enable= for\n"
"home-manager hosts, wiring up =services.emacs= (daemon), the tangled\n"
"=~/.config/emacs/{init,early-init}.el=, and the encrypted\n"
"=~/.authinfo.age=."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2752
#, no-wrap
msgid ""
"{ lib, inputs, ... }:\n"
"let\n"
"  withEmacsOverlay = pkgs: pkgs.extend "
"inputs.emacs-overlay.overlays.default;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2756
#, no-wrap
msgid ""
"emacsUnwrapped =\n"
"  pkgs:\n"
"  let\n"
"    epkgs = withEmacsOverlay pkgs;\n"
"  in\n"
"  if pkgs.stdenv.hostPlatform.isDarwin then epkgs.emacs-plus else "
"epkgs.emacs-pgtk;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2766
#, no-wrap
msgid ""
"tangle =\n"
"  pkgs:\n"
"  {\n"
"    name,\n"
"    org,\n"
"  }:\n"
"  pkgs.runCommand name { nativeBuildInputs = [ (emacsUnwrapped pkgs) ]; } "
"''\n"
"    cp ${org} tmp.org\n"
"    emacs -Q --batch --eval \\\n"
"      \"(progn\n"
"        (require 'ob-tangle)\n"
"        (org-babel-tangle-file \\\"tmp.org\\\" \\\"emacs-lisp\\\"))\"\n"
"    install emacs-lisp $out\n"
"  '';"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2781
#, no-wrap
msgid ""
"tangleEl =\n"
"  pkgs: org:\n"
"  let\n"
"    stem = name: lib.head (lib.splitString \".\" name);\n"
"  in\n"
"  tangle pkgs {\n"
"    name = \"${stem (baseNameOf (toString org))}.el\";\n"
"    inherit org;\n"
"  };"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2791
#, no-wrap
msgid ""
"  mkEmacs =\n"
"    pkgs:\n"
"    (withEmacsOverlay pkgs).callPackage ./package.nix {\n"
"      defaultInitFile = tangle pkgs {\n"
"        name = \"default.el\";\n"
"        org = ./init.org;\n"
"      };\n"
"      org-clickup-src = inputs.org-clickup;\n"
"    };\n"
"in\n"
"{\n"
"  flake.modules.homeManager.emacs =\n"
"    {\n"
"      config,\n"
"      lib,\n"
"      pkgs,\n"
"      ...\n"
"    }:\n"
"    {\n"
"      options.my.programs.emacs.enable = lib.mkEnableOption \"emacs\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2812
#, no-wrap
msgid ""
"config = lib.mkIf config.my.programs.emacs.enable {\n"
"  programs.emacs = {\n"
"    enable = true;\n"
"    package = mkEmacs pkgs;\n"
"  };"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2818
#, no-wrap
msgid ""
"services.emacs = {\n"
"  enable = true;\n"
"  client.enable = true;\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2823
#, no-wrap
msgid ""
"xdg.configFile.\"emacs/init.el\".source = tangleEl pkgs ./init.org;\n"
"xdg.configFile.\"emacs/early-init.el\".source = tangleEl pkgs "
"./early-init.org;\n"
"home.file.\".authinfo.age\".source = ./authinfo.age;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2827
#, no-wrap
msgid ""
"    home.shellAliases = lib.optionalAttrs pkgs.stdenv.hostPlatform.isDarwin "
"{\n"
"      emacs = "
"\"${config.programs.emacs.package}/Applications/Emacs.app/Contents/MacOS/Emacs\";\n"
"    };\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2833
#, no-wrap
msgid ""
"  perSystem =\n"
"    { pkgs, ... }:\n"
"    {\n"
"      packages.emacs = mkEmacs pkgs;\n"
"    };\n"
"}"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:2842
#, no-wrap
msgid ""
"{\n"
"  stdenv,\n"
"  age,\n"
"  beancount,\n"
"  beancount-language-server,\n"
"  emacs-pgtk,\n"
"  emacs-plus,\n"
"  emacsWithPackagesFromUsePackage,\n"
"  gettext,\n"
"  nixd,\n"
"  nixfmt,\n"
"  notmuch,\n"
"  terraform-ls,\n"
"  yaml-language-server,\n"
