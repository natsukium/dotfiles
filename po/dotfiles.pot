#. type: paragraph
#: configuration.org:1072
msgid ""
"Each per-system concern lives in its own =modules/per-system/*.nix= file, "
"documented in =[[Per-system modules]]= below. The outputs body wires them "
"via =imports=; flake-parts merges =perSystem= contributions across all "
"modules."
msgstr ""

#. type: keyword NAME
#: configuration.org:1076
#, no-wrap
msgid "outputs"
msgstr ""

#. type: paragraph in src
#: configuration.org:1078
#, no-wrap
msgid ""
"systems = [\n"
"  \"x86_64-linux\"\n"
"  \"aarch64-linux\"\n"
"  \"aarch64-darwin\"\n"
"];"
msgstr ""

#. type: paragraph in src
#: configuration.org:1084
#, no-wrap
msgid ""
"imports = [\n"
"  ./modules\n"
"];"
msgstr ""

#. type: paragraph in src
#: configuration.org:1088
#, no-wrap
msgid ""
"flake = {\n"
"  overlays = import ./overlays { inherit inputs; };\n"
"};"
msgstr ""

#. type: heading ***
#: configuration.org:1093
#, no-wrap
msgid "Per-system modules"
msgstr ""

#. type: paragraph
#: configuration.org:1095
msgid ""
"Per-concern flake-parts modules that each contribute to "
"=perSystem=. Splitting them keeps =flake.nix= small and lets each concern "
"carry its own documentation.  flake-parts merges contributions across all "
"imported modules, so each file only needs to define what it owns."
msgstr ""

#. type: paragraph
#: configuration.org:1100
msgid "The shared pattern is:"
msgstr ""

#. type: paragraph in SRC
#: configuration.org:1103
#, no-wrap
msgid ""
"{ ... }: # or { self, inputs, ... }: when the module needs them\n"
"{\n"
"  perSystem =\n"
"    { ... }: # the usual perSystem args (pkgs, self', config, system, ...)\n"
"    {\n"
"      <the-attribute-this-module-owns> = { ... };\n"
"    };\n"
"}"
msgstr ""

#. type: heading ****
#: configuration.org:1113
#, no-wrap
msgid "Nixpkgs instance"
msgstr ""

#. type: paragraph
#: configuration.org:1115
msgid ""
"Constructs the per-system =pkgs= with overlays applied, exposed to all other "
"=perSystem= consumers via =_module.args.pkgs=."
msgstr ""

#. type: paragraph
#: configuration.org:1118
msgid ""
"=allowUnfree= is enabled because several desktop hosts pull in unfree "
"packages (NVIDIA drivers on =kilimanjaro=, =1password=, etc.) and gating "
"each call-site with an override would only add noise."
msgstr ""

#. type: paragraph in src
#: configuration.org:1123
#, no-wrap
msgid ""
"{ self, inputs, ... }:\n"
"{\n"
"  perSystem =\n"
"    { system, ... }:\n"
"    {\n"
"      _module.args.pkgs = import inputs.nixpkgs {\n"
"        inherit system;\n"
"        config.allowUnfree = true;\n"
"        overlays = [ inputs.nur-packages.overlays.default ] ++ "
"builtins.attrValues self.overlays;\n"
"      };\n"
"    };\n"
"}"
msgstr ""

#. type: heading ****
#: configuration.org:1137
#, no-wrap
msgid "Checks"
msgstr ""

#. type: paragraph
#: configuration.org:1139
msgid ""
"Re-exports the NixOS VM tests under =./tests= as flake checks for the "
"current system. Kept in its own module so the test wiring is easy to find "
"independent of the per-system =pkgs= construction."
msgstr ""

#. type: paragraph in src
#: configuration.org:1144
#, no-wrap
msgid ""
"{ inputs, self, ... }:\n"
"{\n"
"  perSystem =\n"
"    { pkgs, ... }:\n"
"    {\n"
"      checks = import ../../tests {\n"
"        inherit (inputs) nixpkgs;\n"
"        inherit pkgs self;\n"
"      };\n"
"    };\n"
"}"
msgstr ""

#. type: heading ****
#: configuration.org:1157
#, no-wrap
msgid "Packages"
msgstr ""

#. type: paragraph
#: configuration.org:1159
msgid "Per-system packages exposed as flake outputs."
msgstr ""

#. type: paragraph in src
#: configuration.org:1162
#, no-wrap
msgid ""
"{ ... }:\n"
"{\n"
"  perSystem =\n"
"    {\n"
"      pkgs,\n"
"      lib,\n"
"      ...\n"
"    }:\n"
"    {\n"
"      packages = {\n"
"        fastfetch = pkgs.callPackage ../../pkgs/fastfetch { };\n"
"        html =\n"
"          with pkgs;\n"
"          let\n"
"            org-html-themes = fetchurl {\n"
"              url = "
"\"https://raw.githubusercontent.com/fniessen/org-html-themes/b3898f4c5b09b3365fd93fd1566f46ecd0a8911f/org/theme-readtheorg.setup\";\n"
"              hash = "
"\"sha256-+5gy+S6NcuvlV61fudbCNoCKmSrCdA9P5CHeGKlDrSM=\";\n"
"            };\n"
"            org-to-html = ../../scripts/org-to-html.el;\n"
"          in\n"
"          stdenvNoCC.mkDerivation {\n"
"            name = \"dotfiles\";\n"
"            src = lib.cleanSource ../..;\n"
"            postPatch = ''\n"
"              substituteInPlace configuration.org \\\n"
"                --replace-fail "
"\"https://fniessen.github.io/org-html-themes/org/theme-readtheorg.setup\" "
"\"${org-html-themes}\"\n"
"            '';\n"
"            nativeBuildInputs = [\n"
"              (emacs.pkgs.withPackages (epkgs: [\n"
"                epkgs.htmlize\n"
"                epkgs.nix-ts-mode\n"
"                (epkgs.treesit-grammars.with-grammars (g: [ "
"g.tree-sitter-nix ]))\n"
"              ]))\n"
"              gettext\n"
"              po4a\n"
"            ];\n"
"            buildPhase = ''\n"
"              runHook preBuild\n"
"              po4a po4a.cfg\n"
"              emacs --batch -l ${org-to-html}\n"
"              runHook postBuild\n"
"            '';"
msgstr ""

#. type: paragraph in src
#: configuration.org:1205
