#. type: heading ***
#: modules/configuration.org:3348
#, no-wrap
msgid "Session and hint helpers"
msgstr ""

#. type: paragraph
#: modules/configuration.org:3350
msgid ""
"The keymap points at six shell programs, none touching the module system; "
"their =writeShellApplication= bodies would bury the configuration if they "
"sat in =default.nix=, so they live in a sibling =utilities.nix= handed the "
"felis client, spoor, and Neovim. Besides =felis-switch= and the two hints "
"above, it holds =felis-kill=, the multi-select cousin that tears sessions "
"down; =felis-grep=, a cross-session scrollback search the built-in "
"per-session facet can't do; and =felis-scrollback=, which opens the "
"scrollback =pipe= region read-only in Neovim so editor motions replace the "
"pager."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3365
#, no-wrap
msgid ""
"{\n"
"  lib,\n"
"  pkgs,\n"
"  package,\n"
"  neovim,\n"
"  spoor,\n"
"}:\n"
"let\n"
"  felis-switch = pkgs.writeShellApplication {\n"
"    name = \"felis-switch\";\n"
"    runtimeInputs = [\n"
"      package\n"
"      pkgs.fzf\n"
"      pkgs.gawk\n"
"    ];\n"
"    text = ''\n"
"      list=$(felis sessions list)\n"
"      if [ -z \"$list\" ] || [ \"$list\" = \"no sessions\" ]; then\n"
"        echo \"no sessions\" >&2\n"
"        exit 0\n"
"      fi"
msgstr ""

#. type: cell column 0
#: modules/configuration.org:3396
#, no-wrap
msgid "awk -v self=\"''${FELIS_SESSION_ID:-}\" '$1 != self' \\"
msgstr ""

#. type: cell column 0
#: modules/configuration.org:3397 modules/configuration.org:3427
#, no-wrap
msgid "fzf --ansi \\"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3394
#, no-wrap
msgid ""
"selection=$(\n"
"  printf '%s\\n' \"$list\" \\\n"
"          --with-nth=2.. \\\n"
"          --prompt='felis session> ' \\\n"
"          --preview='felis sessions capture {1} --ansi 2>/dev/null || echo "
"\"(attached — preview unavailable)\"'\n"
") || exit 0"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3403
#, no-wrap
msgid ""
"    id=''${selection%% *}\n"
"    [ -n \"$id\" ] && felis sessions switch \"$id\"\n"
"  '';\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3411
#, no-wrap
msgid ""
"felis-kill = pkgs.writeShellApplication {\n"
"  name = \"felis-kill\";\n"
"  runtimeInputs = [\n"
"    package\n"
"    pkgs.fzf\n"
"    pkgs.gawk\n"
"  ];\n"
"  text = ''\n"
"    list=$(felis sessions list)\n"
"    if [ -z \"$list\" ] || [ \"$list\" = \"no sessions\" ]; then\n"
"      echo \"no sessions\" >&2\n"
"      exit 0\n"
"    fi"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3425
#, no-wrap
msgid ""
"selection=$(\n"
"  printf '%s\\n' \"$list\" \\\n"
"          --multi \\\n"
"          --with-nth=2.. \\\n"
"          --prompt='kill session(s)> ' \\\n"
"          --preview='felis sessions capture {1} --ansi 2>/dev/null || echo "
"\"(attached — preview unavailable)\"'\n"
") || exit 0"
msgstr ""

#. type: cell column 0
#: modules/configuration.org:3435 modules/configuration.org:3456
#, no-wrap
msgid "awk 'NF {print $1}' \\"
msgstr ""

#. type: cell column 0
#: modules/configuration.org:3436 modules/configuration.org:3457
#, no-wrap
msgid "while read -r id; do"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3434
#, no-wrap
msgid ""
"    printf '%s\\n' \"$selection\" \\\n"
"          felis sessions kill \"$id\"\n"
"        done\n"
"  '';\n"
"};"
msgstr ""

#. type: cell column 0
#: modules/configuration.org:3459
#, no-wrap
msgid "awk -v id=\"$id\" 'NF {print id\"\\t\"$0}'"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3446
#, no-wrap
msgid ""
"felis-grep = pkgs.writeShellApplication {\n"
"  name = \"felis-grep\";\n"
"  runtimeInputs = [\n"
"    package\n"
"    pkgs.fzf\n"
"    pkgs.gawk\n"
"  ];\n"
"  text = ''\n"
"    matches=$(\n"
"      felis sessions list \\\n"
"            felis sessions capture \"$id\" --scrollback 2>/dev/null \\\n"
"          done\n"
"    )\n"
"    if [ -z \"$matches\" ]; then\n"
"      echo \"no scrollback\" >&2\n"
"      exit 0\n"
"    fi"
msgstr ""

#. type: cell column 0
#: modules/configuration.org:3469
#, no-wrap
msgid "fzf --delimiter='\\t' --with-nth=2.. --prompt='grep scrollback> '"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3467
#, no-wrap
msgid ""
"selection=$(\n"
"  printf '%s\\n' \"$matches\" \\\n"
") || exit 0"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3472
#, no-wrap
msgid ""
"    id=$(printf '%s' \"$selection\" | awk -F'\\t' '{print $1; exit}')\n"
"    [ -n \"$id\" ] && felis sessions switch \"$id\"\n"
"  '';\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3482
#, no-wrap
msgid ""
"felis-scrollback = pkgs.writeShellApplication {\n"
"  name = \"felis-scrollback\";\n"
"  runtimeInputs = [ neovim ];\n"
"  text = ''\n"
"    exec nvim -R \\\n"
"      -c 'setlocal noswapfile' \\\n"
"      -c 'normal! G' \\\n"
"      \"''${1:?no region file}\"\n"
"  '';\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3500
#, no-wrap
msgid ""
"felis-hints = pkgs.writeShellApplication {\n"
"  name = \"felis-hints\";\n"
"  runtimeInputs = [\n"
"    spoor\n"
"  ]\n"
"  ++ lib.optional pkgs.stdenv.hostPlatform.isLinux pkgs.xdg-utils;\n"
"  text = ''\n"
"    exec spoor --preset url --action open \"''${1:?no region file}\"\n"
"  '';\n"
"};"
msgstr ""

#. type: cell column 0
#: modules/configuration.org:3528
#, no-wrap
msgid "sed 's/^nix log //' \\"
msgstr ""

#. type: cell column 0
#: modules/configuration.org:3529
#, no-wrap
msgid "awk '!seen[$0]++'"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3516
#, no-wrap
msgid ""
"  felis-nix-log = pkgs.writeShellApplication {\n"
"    name = \"felis-nix-log\";\n"
"    runtimeInputs = [\n"
"      pkgs.nix\n"
"      pkgs.fzf\n"
"      pkgs.gnused\n"
"      pkgs.gawk\n"
"      pkgs.less\n"
"    ];\n"
"    text = ''\n"
"      mapfile -t drvs < <(\n"
"        grep -oE 'nix log /nix/store/[a-z0-9]{32}-[^ ]+\\.drv' \"''${1:?no "
"region file}\" \\\n"
"      )\n"
"      case ''${#drvs[@]} in\n"
"        0) echo \"no 'nix log <drv>' on screen\" >&2; exit 0 ;;\n"
"        1) drv=''${drvs[0]} ;;\n"
"        *) drv=$(printf '%s\\n' \"''${drvs[@]}\" | fzf --prompt='nix log> ') "
"|| exit 0 ;;\n"
"      esac\n"
"      [ -n \"$drv\" ] && nix log \"$drv\" | less -R\n"
"    '';\n"
"  };\n"
"in\n"
"{\n"
"  inherit\n"
"    felis-switch\n"
"    felis-kill\n"
"    felis-grep\n"
"    felis-scrollback\n"
"    felis-hints\n"
"    felis-nix-log\n"
"    ;\n"
"}"
msgstr ""

#. type: heading **
#: modules/configuration.org:3554
#, no-wrap
msgid "Spotlight"
msgstr ""

#. type: paragraph
#: modules/configuration.org:3556
msgid ""
"I don't use Spotlight search, yet its indexer (=mdworker=) keeps consuming "
"CPU, disk I/O, and disk space in the background, so I turn indexing off by "
"default. Hosts that want it back can set =enableIndex = true=. nix-darwin "
"has no option for this, so the module drives =mdutil= from an activation "
"script."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3567
#, no-wrap
msgid ""
"{ ... }:\n"
"{\n"
"  flake.modules.darwin.spotlight =\n"
"    { config, lib, ... }:\n"
"    let\n"
"      cfg = config.my.services.spotlight;\n"
"    in\n"
"    {\n"
"      <<spotlight-options>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3577
#, no-wrap
msgid ""
"      <<spotlight-config>>\n"
"    };\n"
"}"
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:3584
#, no-wrap
msgid "spotlight-options"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3586
#, no-wrap
msgid ""
"options.my.services.spotlight = {\n"
"  enableIndex = lib.mkOption {\n"
"    type = lib.types.bool;\n"
"    default = false;\n"
"    description = \"Whether Spotlight indexes the volumes on this "
"machine.\";\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph
#: modules/configuration.org:3597
msgid ""
"=mdutil= targets all volumes with =-a= rather than just =/=: modern macOS "
"splits the boot disk into a read-only System volume (=/=) and a writable "
"Data volume, so =mdutil -i off /= silently leaves the Data volume "
"indexing. When disabling, =mdutil -E= also erases the orphaned index stores "
"to reclaim disk space."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:3602
#, no-wrap
msgid "spotlight-config"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:3604
#, no-wrap
msgid ""
"config = {\n"
"  system.activationScripts.extraActivation.text =\n"
"    if cfg.enableIndex then\n"
"      ''\n"
"        echo \"enabling spotlight indexing...\"\n"
"        mdutil -i on -a &> /dev/null\n"
"      ''\n"
"    else\n"
"      ''\n"
"        echo \"disabling spotlight indexing...\"\n"
"        mdutil -i off -d -a &> /dev/null\n"
"        mdutil -E -a &> /dev/null\n"
"      '';\n"
"};"
msgstr ""
