"                rev = \"66444c3c02bd4121f7127ced30dfc5b1d29b5bcf\";\n"
"                hash = "
"\"sha256-jhbn2eICx7Sf8lm7d5/6cYM3Cl1b/llQyVKuAQvWVWE=\";\n"
"              };\n"
"              npmDeps = pkgs.fetchNpmDeps {\n"
"                inherit (finalAttrs) src;\n"
"                hash = "
