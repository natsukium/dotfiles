#. type: heading ***
#: modules/configuration.org:1286
#, no-wrap
msgid "Async Prompt Module"
msgstr ""

#. type: paragraph
#: modules/configuration.org:1288
msgid ""
"Starship's default fish integration is replaced with an asynchronous "
"variant, gated on the same module's =enableFishAsyncPrompt= toggle rather "
"than a separate file, since the two options always travel together. The "
"async prompt script is cherry-picked from "
"[[https://gist.github.com/duament/bac0181935953b97ca71640727c9c029][duament's "
"gist]], based on "
"[[https://github.com/acomagu/fish-async-prompt][fish-async-prompt]].  See "
"also "
"[[https://github.com/fish-shell/fish-shell/issues/8223][fish-shell#8223]] "
"for upstream discussion on async prompt support."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:1295
#, no-wrap
msgid "starship-async-prompt-config"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1297
#, no-wrap
msgid ""
"(lib.mkIf cfg.enableFishAsyncPrompt {\n"
"  programs.starship.enableFishIntegration = lib.mkForce false;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1301
#, no-wrap
msgid ""
"  programs.fish.interactiveShellInit = ''\n"
"    if test \"$TERM\" != dumb\n"
"        ${lib.getExe config.programs.starship.package} init fish | source\n"
"        source ${./async_prompt.fish}\n"
"    end\n"
"  '';\n"
"})"
msgstr ""

#. type: heading ****
#: modules/configuration.org:1310
#, no-wrap
msgid "Async Prompt Script"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1319
#, no-wrap
msgid ""
"status is-interactive\n"
"or exit 0"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1322
#, no-wrap
msgid ""
"if test -n \"$XDG_RUNTIME_DIR\"\n"
"    set -g __starship_async_tmpdir \"$XDG_RUNTIME_DIR\"/fish-async-prompt\n"
"else\n"
"    set -g __starship_async_tmpdir /tmp/fish-async-prompt\n"
"end\n"
"mkdir -p \"$__starship_async_tmpdir\"\n"
"set -g __starship_async_signal SIGUSR1"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1331
#, no-wrap
msgid ""
"set -g VIRTUAL_ENV_DISABLE_PROMPT 1\n"
"builtin functions -e fish_mode_prompt\n"
"set -gx STARSHIP_SHELL fish\n"
"set -gx STARSHIP_SESSION_KEY (random 10000000000000 9999999999999999)"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1337
#, no-wrap
msgid ""
"function fish_prompt\n"
"    printf '\\e[0J' # Clear from cursor to end of screen\n"
"    if test -e \"$__starship_async_tmpdir\"/\"$fish_pid\"_fish_prompt\n"
"        cat \"$__starship_async_tmpdir\"/\"$fish_pid\"_fish_prompt\n"
"    else\n"
"        __starship_async_simple_prompt\n"
"    end\n"
"end"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1347
#, no-wrap
msgid ""
"function __starship_async_fire --on-event fish_prompt\n"
"    switch \"$fish_key_bindings\"\n"
"        case fish_hybrid_key_bindings fish_vi_key_bindings\n"
"            set STARSHIP_KEYMAP \"$fish_bind_mode\"\n"
"        case '*'\n"
"            set STARSHIP_KEYMAP insert\n"
"    end\n"
"    set STARSHIP_CMD_PIPESTATUS $pipestatus\n"
"    set STARSHIP_CMD_STATUS $status\n"
"    set STARSHIP_DURATION \"$CMD_DURATION\"\n"
"    set STARSHIP_JOBS (count (jobs -p))"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1359
#, no-wrap
msgid ""
"    set -l tmpfile \"$__starship_async_tmpdir\"/\"$fish_pid\"_fish_prompt\n"
"    fish -c '\n"
"starship prompt --terminal-width=\"'$COLUMNS'\" "
"--status='$STARSHIP_CMD_STATUS' --pipestatus=\"'$STARSHIP_CMD_PIPESTATUS'\" "
"--keymap='$STARSHIP_KEYMAP' --cmd-duration='$STARSHIP_DURATION' "
"--jobs='$STARSHIP_JOBS' > '$tmpfile'\n"
"kill -s \"'$__starship_async_signal'\" '$fish_pid &\n"
"    disown\n"
"end"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1366
#, no-wrap
msgid ""
"function __starship_async_simple_prompt\n"
"    set_color brgreen\n"
"    echo -n '❯'\n"
"    set_color normal\n"
"    echo ' '\n"
"end"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1373
#, no-wrap
msgid ""
"function __starship_async_repaint_prompt --on-signal "
"\"$__starship_async_signal\"\n"
"    commandline -f repaint\n"
"end"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1377
#, no-wrap
msgid ""
"function __starship_async_cleanup --on-event fish_exit\n"
"    rm -f \"$__starship_async_tmpdir\"/\"$fish_pid\"_fish_prompt\n"
"end"
msgstr ""

