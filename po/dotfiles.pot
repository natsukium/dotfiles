#. type: heading **
#: configuration.org:1223 modules/configuration.org:297
#, no-wrap
msgid "Distributed Builds"
msgstr ""

#. type: paragraph
#: configuration.org:1225
msgid ""
"[[https://nix.dev/manual/nix/latest/advanced-topics/distributed-builds][Distributed "
"build]] configuration using Nix's built-in =buildMachines= support. This "
"allows any machine in the fleet to offload builds to other machines, "
"significantly reducing build times for resource-intensive derivations."
msgstr ""

#. type: paragraph
#: configuration.org:1229
msgid ""
"This lives outside the =modules/= registry because it has no enable toggle: "
"every non-server host applies it unconditionally, and the profiles that need "
"to opt out (=profile-server=) do so by overriding =nix.distributedBuilds= "
"directly rather than through a toggle here."
msgstr ""

#. type: paragraph
#: configuration.org:1234
msgid ""
"=nix.distributedBuilds= is set to =mkDefault true= here so that server "
"profiles can override it to =false=. =nix.buildMachines= is harmless when "
"distributed builds are disabled, so no conditional wrapping is needed. The "
"server profile (=modules/profiles/server.nix=) disables it because build "
"servers have the resources to build locally, and offloading from one build "
"server to another creates unnecessary network overhead and potential "
"circular dependencies."
msgstr ""

#. type: paragraph in src
#: configuration.org:1247
#, no-wrap
msgid ""
"{\n"
"  inputs,\n"
"  config,\n"
"  lib,\n"
"  ...\n"
"}:\n"
"let\n"
"  <<build-machines-let>>\n"
"in\n"
"{\n"
"  <<distributed-builds-config>>"
msgstr ""

#. type: paragraph in src
#: configuration.org:1259
#, no-wrap
msgid ""
"  <<build-machines-known-hosts>>\n"
"}"
msgstr ""

#. type: heading ***
#: configuration.org:1263
#, no-wrap
msgid "Protocol Selection"
msgstr ""

#. type: paragraph
#: configuration.org:1265
msgid ""
"The =ssh-ng= protocol is preferred over plain =ssh= because it supports "
"content-addressed derivations and more efficient store path "
"transfers. However, Hydra does not support =ssh-ng= (see "
"[[https://github.com/NixOS/hydra/issues/688][NixOS/hydra#688]]), so the "
"protocol is dynamically selected based on whether Hydra is enabled on the "
"current machine."
msgstr ""

#. type: keyword NAME
#: configuration.org:1270
#, no-wrap
msgid "build-machines-let"
msgstr ""

#. type: paragraph in src
#: configuration.org:1272
#, no-wrap
msgid ""
"protocol = if (config.services ? hydra && config.services.hydra.enable) then "
"\"ssh\" else \"ssh-ng\";\n"
"inherit (inputs.self.outputs.nixosConfigurations) kilimanjaro serengeti "
"tarangire;\n"
"inherit (inputs.self.outputs.darwinConfigurations) mikumi;"
msgstr ""

#. type: keyword NAME
#: configuration.org:1279
#, no-wrap
msgid "distributed-builds-config"
msgstr ""

#. type: paragraph in src
#: configuration.org:1281
#, no-wrap
msgid ""
"nix = {\n"
"  distributedBuilds = lib.mkDefault true;"
msgstr ""

#. type: paragraph in src
#: configuration.org:1284
#, no-wrap
msgid ""
"extraOptions = ''\n"
"  builders-use-substitutes = true\n"
"'';"
msgstr ""

#. type: paragraph in src
#: configuration.org:1288
#, no-wrap
msgid ""
"  <<build-machines-list>>\n"
"};"
msgstr ""

#. type: heading ***
#: configuration.org:1292
#, no-wrap
msgid "Build Machines"
msgstr ""

#. type: paragraph
#: configuration.org:1294
msgid ""
"Each machine excludes itself from the build machine list (via "
"=config.networking.hostName= checks) to avoid circular build delegation. The "
"=mikumi= machine is also excluded from the =work= host because the work "
"machine should not offload builds to personal infrastructure."
msgstr ""

#. type: paragraph
#: configuration.org:1299
msgid ""
"Machine capabilities (=maxJobs=, =system-features=) are referenced from each "
"machine's configuration rather than hardcoded. See each machine's definition "
"under =hosts/= for the actual values (e.g., "
"=hosts/nixos/tarangire/default.nix= for =max-jobs = 12=)."
msgstr ""

#. type: keyword NAME
#: configuration.org:1303
#, no-wrap
msgid "build-machines-list"
msgstr ""

#. type: paragraph in src
#: configuration.org:1305
#, no-wrap
msgid ""
"buildMachines =\n"
"  [ ]\n"
"  ++ lib.optional (config.networking.hostName != \"tarangire\") {\n"
"    inherit (tarangire.config.networking) hostName;\n"
"    systems = [\n"
"      \"x86_64-linux\"\n"
"      \"i686-linux\"\n"
"    ];\n"
"    sshUser = \"natsukium\";\n"
"    inherit protocol;\n"
"    maxJobs = tarangire.config.nix.settings.max-jobs;\n"
"    speedFactor = 1;\n"
"    supportedFeatures = tarangire.config.nix.settings.system-features;\n"
"    mandatoryFeatures = [ ];\n"
"  }\n"
"  ++ lib.optional (config.networking.hostName != \"kilimanjaro\") {\n"
"    inherit (kilimanjaro.config.networking) hostName;\n"
"    systems = [\n"
"      \"x86_64-linux\"\n"
"      \"i686-linux\"\n"
"    ];\n"
"    sshUser = \"natsukium\";\n"
"    inherit protocol;\n"
"    maxJobs = kilimanjaro.config.nix.settings.max-jobs;\n"
"    speedFactor = 1;\n"
"    supportedFeatures = kilimanjaro.config.nix.settings.system-features;\n"
"    mandatoryFeatures = [ ];\n"
"  }\n"
"  ++ lib.optional (config.networking.hostName != \"serengeti\") {\n"
"    inherit (serengeti.config.networking) hostName;\n"
"    system = \"aarch64-linux\";\n"
"    sshUser = \"natsukium\";\n"
"    inherit protocol;\n"
"    maxJobs = serengeti.config.nix.settings.max-jobs;\n"
"    speedFactor = 1;\n"
"    supportedFeatures = serengeti.config.nix.settings.system-features;\n"
"    mandatoryFeatures = [ ];\n"
"  }\n"
"  ++ lib.optional (config.networking.hostName != \"mikumi\" && "
"config.networking.hostName != \"work\") {\n"
"    inherit (mikumi.config.networking) hostName;\n"
"    systems = [\n"
"      \"aarch64-darwin\"\n"
"      \"x86_64-darwin\"\n"
"    ];\n"
"    sshUser = \"natsukium\";\n"
"    inherit protocol;\n"
"    maxJobs = mikumi.config.nix.settings.max-jobs;\n"
"    speedFactor = 1;\n"
"    supportedFeatures = [\n"
"      \"apple-virt\"\n"
"      \"benchmark\"\n"
"      \"big-parallel\"\n"
"      \"nixos-test\"\n"
"    ];\n"
"    mandatoryFeatures = [ ];\n"
"  };"
msgstr ""

