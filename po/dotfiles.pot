#: modules/configuration.org:708
#, no-wrap
msgid ""
"  <<fish-extra-abbrs>>\n"
"'';"
msgstr ""

#. type: heading ****
#: modules/configuration.org:712
#, no-wrap
msgid "Keybindings"
msgstr ""

#. type: paragraph
#: modules/configuration.org:714
msgid ""
"=Ctrl+S= is bound to =zi= ([[https://github.com/ajeetdsouza/zoxide][zoxide]] "
"interactive mode) for fuzzy directory jumping."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:716
#, no-wrap
msgid "fish-keybindings"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:718
#, no-wrap
msgid "bind \\cs zi"
msgstr ""

#. type: heading ****
#: modules/configuration.org:721
#, no-wrap
msgid "Pinentry"
msgstr ""

#. type: paragraph
#: modules/configuration.org:723
msgid ""
"When connected via SSH, GPG's pinentry is switched to the curses (terminal) "
"variant.  The default graphical pinentry cannot display on a remote session "
"without X11/Wayland forwarding, so the TUI fallback is necessary for signing "
"commits and decrypting secrets over SSH. See "
"[[https://wiki.gentoo.org/wiki/GnuPG#Changing_pinentry_for_SSH_logins][Gentoo "
"Wiki: GnuPG - Changing pinentry for SSH logins]]."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:728
#, no-wrap
msgid "fish-pinentry"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:731
#, no-wrap
msgid ""
"if test \"$SSH_CONNECTION\" != \"\"\n"
"  set -x PINENTRY_USER_DATA \"USE_CURSES\"\n"
"end"
msgstr ""

#. type: heading ****
#: modules/configuration.org:736
#, no-wrap
msgid "Extra Abbreviations"
msgstr ""

#. type: paragraph
#: modules/configuration.org:738
msgid ""
"Position-aware "
"[[https://fishshell.com/docs/current/cmds/abbr.html][abbreviations]] that "
"use fish's advanced features (=--position anywhere=, =--regex=, "
"=--function=) which are not available through home-manager's =shellAbbrs= "
"option."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:741
#, no-wrap
msgid "fish-extra-abbrs"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:744
#, no-wrap
msgid ""
"abbr -a L --position anywhere --set-cursor \"% | less\"\n"
"abbr -a !! --position anywhere --function _abbr_last_history_item\n"
"abbr -a extract_tar_gz --position command --regex \".+\\.tar\\.gz\" "
"--function _abbr_extract_tar_gz\n"
"abbr -a dotdot --regex '^\\.\\.+$' --function _abbr_multicd"
msgstr ""

