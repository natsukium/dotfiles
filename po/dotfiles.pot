msgid ""
";; (add-hook 'eldoc-documentation-functions #'embark-eldoc-first-target)\n"
";; (setq eldoc-documentation-strategy #'eldoc-documentation-compose-eagerly)"
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/init.org:271
