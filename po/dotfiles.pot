#. type: paragraph
#: modules/features/emacs/init.org:1172
msgid ""
"The compilation buffer does not inherit from comint-mode, so ANSI escape "
"sequences are displayed as raw text by default.  Adding "
"=ansi-color-compilation-filter= to the compilation filter hook interprets "
"these sequences and renders them as colors."
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/init.org:1178
#, no-wrap
msgid "(add-hook 'compilation-filter-hook 'ansi-color-compilation-filter)"
msgstr ""

#. type: heading **
#: modules/features/emacs/init.org:1181
#, no-wrap
msgid "copy-region-reference"
msgstr ""

#. type: paragraph
#: modules/features/emacs/init.org:1183
msgid ""
"Copy the absolute path and line range of the selected region in "
"=file:start-end= format (e.g. =/path/to/file.el:10-20=).  Pasting the result "
"into a coding agent's prompt gives it an unambiguous file reference to work "
"with."
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/init.org:1189
#, no-wrap
msgid ""
"(defun my/copy-region-reference (start end)\n"
"  \"Copy the file path and line range of the current region to the "
"clipboard.\n"
"The format is \\\"/path/to/file:START-END\\\".\"\n"
"  (interactive \"r\")\n"
"  (let* ((file (buffer-file-name))\n"
"         (line-start (line-number-at-pos start))\n"
"         (line-end (line-number-at-pos (1- end)))\n"
"         (ref (format \"%s:%d-%d\" file line-start line-end)))\n"
"    (kill-new ref)\n"
"    (message \"%s\" ref)))"
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/init.org:1200
#, no-wrap
msgid "(global-set-key (kbd \"C-c r\") #'my/copy-region-reference)"
msgstr ""

