msgstr ""

#. type: heading ****
#: modules/configuration.org:1873
#, no-wrap
msgid "Pull"
msgstr ""

#. type: paragraph
#: modules/configuration.org:1875
msgid ""
"=gpm= pulls from the remote's default branch, dynamically detected via =git "
"remote show= rather than hardcoding =main= or =master=. This handles "
"repositories that still use =master= or other branch naming conventions."
msgstr ""

#. type: paragraph
#: modules/configuration.org:1879
msgid ""
"=gpu= pulls from upstream — used in fork workflows to sync with the original "
"repository."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:1881
#, no-wrap
msgid "git-abbr-pull"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:1883
#, no-wrap
