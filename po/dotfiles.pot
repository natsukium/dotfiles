#. type: heading **
#: configuration.org:73
#, no-wrap
msgid "Flake"
msgstr ""

#. type: paragraph
#: configuration.org:75
msgid ""
"This flake manages NixOS, nix-darwin, and home-manager configurations for "
"multiple machines across different platforms (macOS, Linux, Android). It "
"uses flake-parts for modular organization and includes tooling for "
"development, code formatting, and pre-commit hooks."
msgstr ""

#. type: paragraph in src
#: configuration.org:85
#, no-wrap
msgid ""
"{\n"
"  description = \"dotfiles\";"
msgstr ""

#. type: paragraph in src
#: configuration.org:88
#, no-wrap
msgid ""
"inputs = {\n"
"  <<nixpkgs>>\n"
"  <<nixpkgs-stable>>\n"
"  <<flake-parts>>\n"
"  <<flake-utils>>\n"
"  <<darwin>>\n"
"  <<home-manager>>\n"
"  <<nixos-wsl>>\n"
"  <<nix-on-droid>>\n"
"  <<disko>>\n"
"  <<impermanence>>\n"
"  <<lanzaboote>>\n"
"  <<nixos-facter-modules>>\n"
"  <<comin>>\n"
"  <<microvm>>\n"
"  <<niks3>>\n"
"  <<sops-nix>>\n"
"  <<tsnsrv>>\n"
"  <<git-hooks>>\n"
"  <<treefmt-nix>>\n"
"  <<nix-colors>>\n"
"  <<nix-wallpaper>>\n"
"  <<brew-nix>>\n"
"  <<claude-desktop>>\n"
"  <<edgepkgs>>\n"
"  <<emacs-overlay>>\n"
"  <<felis>>\n"
"  <<firefox-addons>>\n"
"  <<hermes-agent>>\n"
"  <<mcp-servers>>\n"
"  <<niri-flake>>\n"
"  <<org-clickup>>\n"
"  <<nur-packages>>\n"
"  <<paneru>>\n"
"  <<simple-wol-manager>>\n"
"  <<spoor>>\n"
"  <<vicinae>>\n"
"  <<zen-browser>>\n"
"};"
msgstr ""

#. type: paragraph in src
#: configuration.org:136
#, no-wrap
msgid ""
"nixConfig = {\n"
"  <<nix-config>>\n"
"};"
msgstr ""

#. type: paragraph in src
#: configuration.org:140
#, no-wrap
msgid ""
"  outputs =\n"
"    { self, flake-parts, ... }@inputs:\n"
"    flake-parts.lib.mkFlake { inherit inputs; } {\n"
"      <<outputs>>\n"
"    };\n"
"}"
msgstr ""

