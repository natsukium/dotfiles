"gpm = \"git pull (git remote show origin | sed -n '/HEAD branch/s/.*: "
"//p')\";\n"
"gpu = \"git pull upstream\";"
msgstr ""

#. type: heading ****
#: modules/configuration.org:1887
#, no-wrap
msgid "Commit"
msgstr ""

#. type: paragraph
#: modules/configuration.org:1889
msgid ""
"=gci= creates a commit. The trailing space allows directly appending =-m "
