#. type: paragraph
#: modules/features/emacs/init.org:1220
msgid ""
"Register all repositories cloned by ghq (https://github.com/x-motemen/ghq) "
"as projects."
msgstr ""

#. type: paragraph
#: modules/features/emacs/init.org:1222
msgid "Specifically, directories under =~/src/$ACCOUNT/$VCS_HOST/$OWNER/$REPO=."
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/init.org:1225
#, no-wrap
msgid ""
"(defun my/sync-project-list ()\n"
"  \"Find all projects under ~/src and synchronize the project-list-file.\"\n"
"  (interactive)\n"
"  (let* (;; 1. Retrieve directory list as a string using find command\n"
"         (command (format \"find %s -mindepth 4 -maxdepth 4 -type d\"\n"
"                          (expand-file-name \"~/src\")))\n"
"         (dir-list-string (shell-command-to-string command))\n"
"         ;; 2. Split string by newlines and exclude empty lines to create a "
"list\n"
"         (dirs (split-string dir-list-string \"\\n\" t)))"
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/init.org:1235
#, no-wrap
msgid ""
";; 3. Build file contents in a temporary buffer\n"
"(with-temp-buffer\n"
"  (insert \";;; -*- lisp-data -*-\\n\")\n"
"  (insert \"(\\n\")\n"
"  (dolist (dir dirs)\n"
"    (insert (format \" (\\\"%s/\\\")\\n\" dir)))\n"
"  (insert \")\\n\")"
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/init.org:1243
#, no-wrap
msgid ""
";; 4. Write the built contents to file\n"
"(write-file project-list-file))))"
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/init.org:1246
#, no-wrap
msgid "(my/sync-project-list)"
msgstr ""

#. type: paragraph
#: modules/features/emacs/init.org:1249
msgid ""
"Sort the project list by modification time, placing recently updated "
"projects first."
msgstr ""

#. type: paragraph
#: modules/features/emacs/init.org:1251
msgid ""
"Using advice instead of sorting in =my/sync-project-list= ensures that "
"projects are sorted by their current mtime at selection time, not at file "
"generation time.  This keeps the order fresh even during long Emacs "
"sessions."
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/init.org:1256
#, no-wrap
msgid ""
"(defun my/sort-projects-by-mtime (projects)\n"
"  \"Sort PROJECTS by modification time, most recent first.\"\n"
"  (sort projects\n"
"        (lambda (a b)\n"
"          (let ((time-a (file-attribute-modification-time\n"
"                         (file-attributes a)))\n"
"                (time-b (file-attribute-modification-time\n"
"                         (file-attributes b))))\n"
"            (time-less-p time-b time-a)))))"
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/init.org:1266
#, no-wrap
msgid "(advice-add 'project-known-project-roots :filter-return"
msgstr ""

#. type: heading **
#: modules/features/emacs/early-init.org:3
#, no-wrap
msgid "disable some bars"
msgstr ""

#. type: paragraph
#: modules/features/emacs/early-init.org:5
msgid ""
"The tool bar duplicates functionality already accessible via keybindings and "
"the menu bar, while the vertical scroll bar wastes horizontal space without "
"providing useful navigation—line numbers and modeline indicators are more "
"precise.  Setting these in ~default-frame-alist~ rather than calling "
"~tool-bar-mode~ / ~scroll-bar-mode~ avoids a brief flash of the bars during "
"startup before the modes disable them."
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/early-init.org:13
#, no-wrap
msgid ""
"(push '(tool-bar-lines . 0) default-frame-alist)\n"
"(push '(vertical-scroll-bars) default-frame-alist)"
msgstr ""

#. type: heading **
#: modules/features/emacs/early-init.org:17
#, no-wrap
msgid "turn off the annoying bell"
msgstr ""

#. type: paragraph
#: modules/features/emacs/early-init.org:19
msgid ""
"The default audible bell is distracting and provides no actionable "
"information.  Replacing it with ~ignore~ silences it entirely; a visual bell "
"(~visible-bell~) was not chosen because the screen flash is equally "
"disruptive."
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/early-init.org:25
#, no-wrap
msgid "(setq ring-bell-function 'ignore)"
msgstr ""

#. type: heading **
#: modules/features/emacs/early-init.org:28
#, no-wrap
msgid "disable backup files"
msgstr ""

#. type: paragraph
#: modules/features/emacs/early-init.org:30
msgid ""
"Emacs already skips backup files for version-controlled files by default "
"(~vc-make-backup-files~ is ~nil~), but files outside of a repository still "
"produce backups.  Since virtually all editing happens in Git-managed trees, "
"the remaining cases are rare enough that the clutter outweighs the safety "
"net.  Auto-save files are likewise redundant when unsaved work can be "
"recovered through Git stashes or reflog."
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/early-init.org:38
#, no-wrap
msgid ""
"(setq make-backup-files nil)\n"
"(setq auto-save-default nil)"
msgstr ""

#. type: heading **
#: modules/features/emacs/early-init.org:42
#, no-wrap
msgid "disable lock files"
msgstr ""

#. type: paragraph
#: modules/features/emacs/early-init.org:44
msgid ""
"Lock files (~.#filename~) prevent concurrent editing across multiple Emacs "
"instances, but in a single-instance workflow they only clutter the working "
"directory and interfere with file watchers and build tools."
msgstr ""

#. type: paragraph in src
#: modules/features/emacs/early-init.org:49
#, no-wrap
msgid "(setq create-lockfiles nil)"
msgstr ""

#. type: keyword OPTIONS
#: overlays/configuration.org:3 modules/configuration.org:3
#, no-wrap
msgid "^:{}"
msgstr ""

#. type: heading *
#: overlays/configuration.org:5 modules/configuration.org:5
#, no-wrap
msgid "Overview"
msgstr ""

#. type: paragraph
#: overlays/configuration.org:7
msgid ""
"This file defines nixpkgs overlays for patching broken packages, pinning "
"specific versions, and adding local workarounds. Each overlay modifies the "
"package set to address issues that would otherwise block the system build or "
"cause runtime problems."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:11
msgid ""
"For details on overlay mechanics (=final: prev:= pattern, composition order, "
"etc.), see [[https://nixos.org/manual/nixpkgs/stable/#chap-overlays][nixpkgs "
"overlay documentation]]."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:14
msgid ""
"Overlays are organized into four categories based on their purpose and "
"expected lifetime:"
msgstr ""

#. type: plain list -
#: overlays/configuration.org:18
#, no-wrap
msgid ""
"*stable*: Packages fetched from nixpkgs-stable when broken in unstable and "
"the fix would\n"
"trigger excessive rebuilds or is too complex to patch locally."
msgstr ""

#. type: plain list -
#: overlays/configuration.org:20
#, no-wrap
msgid ""
"*temporary-fix*: Local overrides (e.g., disabling tests) that don't require "
"a different\n"
"nixpkgs version. Remove once fixed upstream."
msgstr ""

#. type: plain list -
#: overlays/configuration.org:21
#, no-wrap
msgid ""
"*pre-release*: Alpha, beta, or pre-release packages for testing before they "
"land in nixpkgs."
msgstr ""

#. type: plain list -
#: overlays/configuration.org:23
#, no-wrap
msgid ""
"*patches*: Workarounds not suitable for upstream contribution (e.g., "
"locale-specific fixes,\n"
"local tooling shims). Expected to remain indefinitely."
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:30
#, no-wrap
msgid ""
"{ inputs }:\n"
"{\n"
"  <<stable>>"
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:34
#, no-wrap
msgid "<<temporary-fix>>"
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:36
#, no-wrap
msgid "<<pre-release>>"
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:38
#, no-wrap
msgid ""
"  <<patches>>\n"
"}"
msgstr ""

#. type: keyword NAME
#: overlays/configuration.org:42 overlays/configuration.org:48
#, no-wrap
msgid "stable"
msgstr ""

#. type: paragraph
#: overlays/configuration.org:44
msgid ""
"Fetch packages from nixpkgs-stable when broken in unstable. This includes "
"cases where the upstream fix would trigger excessive rebuilds, or where the "
"issue is too complex to patch locally."
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:50
#, no-wrap
msgid ""
"stable = final: prev: {\n"
"};"
msgstr ""

#. type: keyword NAME
#: overlays/configuration.org:54 overlays/configuration.org:61
#, no-wrap
msgid "temporary-fix"
msgstr ""

#. type: paragraph
#: overlays/configuration.org:56
msgid ""
"Local overrides for packages that build but have failing tests or minor "
"issues.  Unlike the =stable= overlay, these don't require fetching packages "
"from a different nixpkgs branch. We simply override specific attributes "
"(like =doCheck=) on the existing packages. Remove these overrides once the "
"issues are fixed upstream."
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:63
#, no-wrap
msgid ""
"temporary-fix = final: prev: {\n"
"  <<python313-package-set>>\n"
"};"
msgstr ""

#. type: heading ***
#: overlays/configuration.org:68
#, no-wrap
msgid "Python313 package set"
msgstr ""

#. type: paragraph
#: overlays/configuration.org:70
msgid "Override problematic Python packages using =packageOverrides=."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:72
msgid ""
"Python packages in nixpkgs form an interconnected dependency graph. The "
"=packageOverrides= mechanism ensures that when a package is overridden, all "
"dependent packages automatically see the modified version. This is essential "
"for consistency—a direct overlay override (e.g., =python313Packages.foo = "
"...=) would only affect top-level access, leaving internal dependencies "
"using the original broken version."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:78
msgid ""
"See "
"[[https://nixos.org/manual/nixpkgs/stable/#overriding-python-packages][nixpkgs "
"Python documentation]] for details."
msgstr ""

#. type: keyword NAME
#: overlays/configuration.org:80
#, no-wrap
msgid "python313-package-set"
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:82
#, no-wrap
msgid ""
"python313 = prev.python313.override {\n"
"  packageOverrides = pyfinal: pyprev: {\n"
"    <<rapidocr-onnxruntime>>\n"
"    <<lxml-html-clean>>\n"
"  };\n"
"};"
msgstr ""

#. type: keyword NAME
#: overlays/configuration.org:90 overlays/configuration.org:98
#, no-wrap
msgid "rapidocr-onnxruntime"
msgstr ""

#. type: paragraph
#: overlays/configuration.org:92
msgid ""
"The test suite causes a segmentation fault during execution. The root cause "
"is still under investigation."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:95
msgid ""
"This package is pulled in as a transitive dependency. Runtime functionality "
"has been verified to work correctly in actual use, so disabling the test "
"suite is a safe workaround."
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:100
#, no-wrap
msgid ""
"rapidocr-onnxruntime = pyprev.rapidocr-onnxruntime.overridePythonAttrs (_: "
"{\n"
"  doCheck = false;\n"
"});"
msgstr ""

#. type: keyword NAME
#: overlays/configuration.org:105 overlays/configuration.org:114
#, no-wrap
msgid "lxml-html-clean"
msgstr ""

#. type: paragraph
#: overlays/configuration.org:107
msgid ""
"Tests fail due to breaking changes in libxml2 2.14, which modified how "
"certain DOM operations handle whitespace and entity encoding. These changes "
"cause test assertions to fail even though the actual HTML cleaning "
"functionality works correctly."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:111
msgid ""
"Tracked upstream in "
"[[https://github.com/fedora-python/lxml_html_clean/issues/24][fedora-python/lxml_html_clean#24]].  "
"Remove this override once the test suite is updated for libxml2 2.14 "
"compatibility."
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:116
#, no-wrap
msgid ""
"lxml-html-clean = pyprev.lxml-html-clean.overridePythonAttrs (_: {\n"
"  doCheck = false;\n"
"});"
msgstr ""

#. type: keyword NAME
#: overlays/configuration.org:121 overlays/configuration.org:127
#, no-wrap
msgid "pre-release"
msgstr ""

#. type: paragraph
#: overlays/configuration.org:123
msgid ""
"Overlay for testing alpha, beta, or pre-release versions of packages before "
"they land in nixpkgs. Useful for evaluating release candidates, nightly "
"builds, or packages pending upstream review. Once a package is available in "
"nixpkgs, remove it from this overlay."
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:129
#, no-wrap
msgid "pre-release = final: prev: { };"
msgstr ""

#. type: keyword NAME
#: overlays/configuration.org:132 overlays/configuration.org:141
#, no-wrap
msgid "patches"
msgstr ""

#. type: paragraph
#: overlays/configuration.org:134
msgid "Workarounds that are not suitable for upstream contribution."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:136
msgid ""
"These patches address issues that upstream would likely not accept—either "
"because they are specific to this configuration (e.g., locale settings), "
"bypass intended behavior, or solve problems in unconventional ways. Unlike "
"=temporary-fix=, these are expected to remain indefinitely."
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:143
#, no-wrap
msgid ""
"patches = final: prev: {\n"
"  <<gh-dash>>\n"
"  <<command-line-tools-shim>>\n"
"};"
msgstr ""

#. type: keyword NAME
#: overlays/configuration.org:149 overlays/configuration.org:162
#, no-wrap
msgid "gh-dash"
msgstr ""

#. type: paragraph
#: overlays/configuration.org:151
msgid ""
"The preview pane renders incorrectly when =LANG=ja_JP.UTF-8= is set. The "
"issue stems from gh-dash's terminal width calculation, which miscounts the "
"display width of certain UTF-8 characters (particularly CJK characters and "
"some emoji). This causes text wrapping and alignment to break."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:156
msgid ""
"Setting =LANG=C.UTF-8= forces ASCII-compatible width calculations while "
"preserving UTF-8 encoding support, which fixes the rendering issue. We use "
"=writeShellApplication= to create a wrapper that sets this environment "
"variable before invoking the real binary."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:160
msgid ""
"Reported upstream in "
"[[https://github.com/dlvhdr/gh-dash/issues/316][dlvhdr/gh-dash#316]]."
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:164
#, no-wrap
msgid ""
"gh-dash =\n"
"  (final.writeShellApplication {\n"
"    name = \"gh-dash\";\n"
"    text = ''\n"
"      LANG=C.UTF-8 ${final.lib.getExe prev.gh-dash} \"$@\"\n"
"    '';\n"
"  }).overrideAttrs\n"
"    { pname = \"gh-dash\"; };"
msgstr ""

#. type: heading ***
#: overlays/configuration.org:174
#, no-wrap
msgid "mkShim"
msgstr ""

#. type: paragraph
#: overlays/configuration.org:176
msgid "Shim utility for providing stub implementations of macOS Command Line Tools."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:178
msgid ""
"On darwin systems without Xcode Command Line Tools installed, invoking "
"commands like =cc= or =python3= triggers an annoying system popup prompting "
"installation.  These shims intercept such calls and either delegate to "
"Nix-provided tools or return appropriate exit codes, suppressing the popup "
"and preventing spurious build failures."
msgstr ""

#. type: paragraph
#: overlays/configuration.org:183
msgid ""
"See [[file:../pkgs/mkShim/][pkgs/mkShim]] for the implementation details and "
"list of shimmed commands."
msgstr ""

#. type: keyword NAME
#: overlays/configuration.org:185
#, no-wrap
msgid "command-line-tools-shim"
msgstr ""

#. type: paragraph in src
#: overlays/configuration.org:187
#, no-wrap
msgid "inherit (final.callPackage ../pkgs/mkShim { }) mkShim commandLineToolsShim;"
msgstr ""

#. type: paragraph
#: modules/configuration.org:7
msgid ""
"This file defines custom modules that extend the standard NixOS, nix-darwin, "
"and home-manager module systems. Each module addresses specific use cases or "
"provides opinionated defaults not available upstream."
msgstr ""

#. type: paragraph
#: modules/configuration.org:11
msgid ""
"Modules are organized by functional domain (e.g., Shell, Networking, Version "
"Control) rather than by module system target. When a domain contains both "
"system-level and user-level configuration, subheaders separate them "
"explicitly."
msgstr ""

#. type: paragraph
#: modules/configuration.org:17
msgid ""
"Nix package manager and nixpkgs configuration. These modules are shared "
"across NixOS and nix-darwin, providing consistent Nix behavior on all "
"machines."
msgstr ""

#. type: heading ***
#: modules/configuration.org:20 modules/configuration.org:1450
#, no-wrap
msgid "Core Settings"
msgstr ""

#. type: paragraph
#: modules/configuration.org:22
msgid ""
"Core Nix daemon configuration including flakes, garbage collection, binary "
"caches, and sandbox settings."
msgstr ""

#. type: paragraph
#: modules/configuration.org:30
msgid ""
"Registered under both NixOS and nix-darwin, since Nix daemon behavior is "
"shared across platforms; the =systemModule= binding lets both classes reuse "
"the exact same module rather than duplicating it. The user-level counterpart "
"([[*User-Level Settings][User-Level Settings]]) is a distinct "
"=flake.modules.homeManager.nix= entry in this same file, since XDG base "
"directories and the global gitignore belong to the home-manager scope, not "
"the system scope."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:38
#, no-wrap
msgid ""
"{ ... }:\n"
"let\n"
"  systemModule =\n"
"    {\n"
"      config,\n"
"      lib,\n"
"      pkgs,\n"
"      ...\n"
"    }:\n"
"    let\n"
"      cfg = config.my.nix;\n"
"    in\n"
"    {\n"
"      <<nix-options>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:53
#, no-wrap
msgid ""
"      <<nix-config>>\n"
"    };\n"
"in\n"
"{\n"
"  flake.modules.nixos.nix = systemModule;\n"
"  flake.modules.darwin.nix = systemModule;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:60
#, no-wrap
msgid ""
"  <<nix-home-manager>>\n"
"}"
msgstr ""

#. type: heading ***
#: modules/configuration.org:64 modules/configuration.org:367
#: modules/configuration.org:3582
#, no-wrap
msgid "Options"
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:66
#, no-wrap
msgid "nix-options"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:68
#, no-wrap
msgid ""
"options.my.nix = {\n"
"  enable = lib.mkEnableOption \"Nix configuration\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:71
#, no-wrap
msgid ""
"  enableFlakes = lib.mkOption {\n"
"    default = true;\n"
"    example = false;\n"
"    description = \"Whether to enable flakes.\";\n"
"    type = lib.types.bool;\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:84
#, no-wrap
msgid ""
"config = lib.mkIf cfg.enable (\n"
"  lib.mkMerge [\n"
"    <<nix-flakes>>\n"
"    {\n"
"      <<nix-store-optimisation>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:90
#, no-wrap
msgid "<<nix-warn-dirty>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:92
#, no-wrap
msgid "<<nix-substituters>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:94
#, no-wrap
msgid "<<nix-sandbox>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:96
#, no-wrap
msgid "<<nix-trusted-users>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:98
#, no-wrap
msgid "<<nix-gc>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:100
#, no-wrap
msgid ""
"      <<nix-extra-options>>\n"
"    }\n"
"  ]\n"
");"
msgstr ""

#. type: heading ****
#: modules/configuration.org:106
#, no-wrap
msgid "Flakes"
msgstr ""

#. type: paragraph
#: modules/configuration.org:108
msgid ""
"Flakes are the de facto standard for Nix project management and are used "
"throughout this repository."
msgstr ""

#. type: paragraph
#: modules/configuration.org:111
msgid ""
"Channels are disabled because they introduce mutable state "
"(=/nix/var/nix/profiles/per-user/*/channels=)  that is difficult to "
"reproduce across machines. However, this does not break legacy commands like "
"=nix-shell= — NixOS and nix-darwin automatically set =NIX_PATH= from the "
"flake's inputs by default (see "
"[[https://search.nixos.org/options?query=nixpkgs.flake.setNixPath][=nixpkgs.flake.setNixPath=]]), "
"so =<nixpkgs>= lookups continue to work on all machines managed by this "
"dotfiles repository."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:117
#, no-wrap
msgid "nix-flakes"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:119
#, no-wrap
msgid ""
"(lib.mkIf cfg.enableFlakes {\n"
"  nix = {\n"
"    settings.experimental-features = [\n"
"      \"flakes\"\n"
"      \"nix-command\"\n"
"    ];\n"
"    channel.enable = false;\n"
"  };\n"
"})"
msgstr ""

#. type: heading ****
#: modules/configuration.org:130
#, no-wrap
msgid "Store Optimisation"
msgstr ""

#. type: paragraph
#: modules/configuration.org:132
msgid "Two complementary deduplication mechanisms are enabled:"
msgstr ""

#. type: plain list -
#: modules/configuration.org:136
#, no-wrap
msgid ""
"=nix.optimise.automatic= periodically runs =nix-store --optimise= to "
"hard-link identical\n"
"files already in the store."
msgstr ""

#. type: plain list -
#: modules/configuration.org:137
#, no-wrap
msgid ""
"=nix.settings.auto-optimise-store= deduplicates at build time as new paths "
"are added."
msgstr ""

#. type: paragraph
#: modules/configuration.org:138
msgid ""
"=auto-optimise-store= is Linux-only because enabling it on macOS corrupts "
"the store — the build fails with =error: cannot link '/nix/store/.tmp-link' "
"to '/nix/store/.links/...': File exists=. See "
"[[https://github.com/NixOS/nix/issues/7273][NixOS/nix#7273]]."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:142
#, no-wrap
msgid "nix-store-optimisation"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:144
#, no-wrap
msgid ""
"nix.optimise.automatic = true;\n"
"nix.settings.auto-optimise-store = pkgs.stdenv.hostPlatform.isLinux;"
msgstr ""

#. type: heading ****
#: modules/configuration.org:148
#, no-wrap
msgid "Garbage Collection"
msgstr ""

#. type: paragraph
#: modules/configuration.org:150
msgid ""
"Periodically runs =nix-collect-garbage= to reclaim disk space. Generations "
"older than 7 days are deleted automatically — keeping old builds beyond that "
"provides little value since they can always be rebuilt from the flake lock "
"file."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:154
#, no-wrap
msgid "nix-gc"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:156
#, no-wrap
msgid ""
"nix.gc = {\n"
"  automatic = true;\n"
"  options = \"--delete-older-than 7d\";\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:162
#, no-wrap
msgid "Dirty Warning"
msgstr ""

#. type: paragraph
#: modules/configuration.org:164
msgid ""
"Suppress the \"Git tree is dirty\" warning during flake evaluation. This "
"warning fires on every build when there are uncommitted changes, which is "
"the normal state during development."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:167
#, no-wrap
msgid "nix-warn-dirty"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:169
#, no-wrap
msgid "nix.settings.warn-dirty = false;"
msgstr ""

#. type: paragraph
#: modules/configuration.org:174
msgid ""
"I configure three binary caches. =nix-cache.natsukium.com= is my self-hosted "
"niks3 cache (on manyara, backed by Cloudflare R2); CI pushes this dotfiles "
"repository's pre-built artifacts to it. =natsukium= is my Cachix cache, "
"which my other repositories still push to — only dotfiles has moved to "
"niks3, so for now niks3 is dotfiles-only and Cachix covers everything else, "
"though I may broaden niks3's scope later. =nix-community= provides caches "
"for community projects, including NVIDIA/CUDA packages and other "
"nix-community-maintained derivations."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:182
#, no-wrap
msgid "nix-substituters"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:184
#, no-wrap
msgid ""
"nix.settings = {\n"
"  substituters = [\n"
"    \"https://nix-cache.natsukium.com\"\n"
"    \"https://natsukium.cachix.org\"\n"
"    \"https://nix-community.cachix.org\"\n"
"  ];"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:191
#, no-wrap
msgid ""
"  trusted-public-keys = [\n"
"    \"niks3-1:SoIFTPtiPoCW3/OzUkIBKlLG5znMZfbihlr11XAOles=\"\n"
"    "
"\"natsukium.cachix.org-1:STD7ru7/5+KJX21m2yuDlgV6PnZP/v5VZWAJ8DZdMlI=\"\n"
"    "
"\"nix-community.cachix.org-1:mB9FSh9qf2dCimDSUo8Zy7bkq5CX+/rkCWyvRCYg3Fs=\"\n"
"  ];\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:199
#, no-wrap
msgid "Sandbox"
msgstr ""

#. type: paragraph
#: modules/configuration.org:201
msgid ""
"The sandbox is set to =\"relaxed\"= on Darwin to avoid unexpected build "
"failures. With =sandbox = true=, some packages fail to build on macOS due to "
"sandbox restrictions — likely related to localhost networking required by "
"test suites that start local servers, though the exact mechanism is not "
"fully understood. Nixpkgs provides =__darwinAllowLocalNetworking= to allow "
"localhost access within the sandbox, which may address the same class of "
"issues. =\"relaxed\"= keeps normal derivations sandboxed while allowing "
"derivations with =__noChroot = true= to bypass the sandbox, preventing these "
"failures."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:210
#, no-wrap
msgid "nix-sandbox"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:212
#, no-wrap
msgid ""
"nix.settings.sandbox = if pkgs.stdenv.hostPlatform.isDarwin then \"relaxed\" "
"else true;"
msgstr ""

#. type: heading ****
#: modules/configuration.org:215
#, no-wrap
msgid "Trusted Users"
msgstr ""

#. type: paragraph
#: modules/configuration.org:217
msgid ""
"On macOS, administrative users belong to the =admin= group, not =wheel= "
"(which only contains =root=). Without =@admin=, the primary user would not "
"be trusted by the Nix daemon on Darwin."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:221
#, no-wrap
msgid "nix-trusted-users"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:223
#, no-wrap
msgid ""
"nix.settings.trusted-users = [\n"
"  \"root\"\n"
"  \"@wheel\"\n"
"]\n"
"++ lib.optional pkgs.stdenv.hostPlatform.isDarwin \"@admin\";"
msgstr ""

#. type: heading ****
#: modules/configuration.org:230
#, no-wrap
msgid "Extra Options"
msgstr ""

#. type: paragraph
#: modules/configuration.org:232
msgid ""
"Terminates builds that produce no output for 3600 seconds (1 hour). Some "
"heavy builds (e.g., Chromium, kernel compilation, CUDA-based deep learning "
"libraries) can be silent for extended periods, so the timeout is set "
"generously to avoid false positives while still catching genuinely hung "
"builds."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:237
#, no-wrap
msgid "nix-extra-options"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:239
#, no-wrap
msgid ""
"nix.extraOptions = ''\n"
"  max-silent-time = 3600\n"
"'';"
msgstr ""

#. type: heading **
#: modules/configuration.org:244
#, no-wrap
msgid "Nixpkgs"
msgstr ""

#. type: paragraph
#: modules/configuration.org:246
msgid ""
"Nixpkgs configuration. =allowUnfree= is enabled by default. While free "
"software is preferred where possible, strictly enforcing it is impractical — "
"NVIDIA hardware requires unfree drivers and CUDA libraries, and specifying "
"each unfree package individually via =allowUnfreePredicate= would be "
"prohibitively tedious for the number of transitive dependencies involved."
msgstr ""

#. type: paragraph
#: modules/configuration.org:257
msgid ""
"Registered under both NixOS and nix-darwin from the same module binding, "
"since nixpkgs configuration has no platform-specific behavior."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:261
#, no-wrap
msgid ""
"{ ... }:\n"
"let\n"
"  module =\n"
"    {\n"
"      config,\n"
"      lib,\n"
"      ...\n"
"    }:\n"
"    let\n"
"      cfg = config.my.nixpkgs;\n"
"    in\n"
"    {\n"
"      options.my.nixpkgs = {\n"
"        enable = lib.mkEnableOption \"Nixpkgs configuration\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:276
#, no-wrap
msgid ""
"  allowUnfree = lib.mkOption {\n"
"    default = true;\n"
"    example = false;\n"
"    description = \"Whether to allow unfree packages.\";\n"
"    type = lib.types.bool;\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:284
#, no-wrap
msgid ""
"      config = lib.mkIf cfg.enable {\n"
"        nixpkgs = {\n"
"          config.allowUnfree = cfg.allowUnfree;\n"
"        };\n"
"      };\n"
"    };\n"
"in\n"
"{\n"
"  flake.modules.nixos.nixpkgs = module;\n"
"  flake.modules.darwin.nixpkgs = module;\n"
"}"
msgstr ""

#. type: paragraph
#: modules/configuration.org:299
msgid ""
"Machine-to-machine build offloading (=nix.buildMachines=) is documented "
"alongside =configuration.org='s top-level "
"[[file:../configuration.org::*Distributed Builds][Distributed Builds]] "
"section rather than here: it has no enable toggle and applies "
"unconditionally, so it is not a =flake.modules= registry entry and does not "
"tangle into anything under =modules/=."
msgstr ""

#. type: heading **
#: modules/configuration.org:304
#, no-wrap
msgid "User-Level Settings"
msgstr ""

#. type: paragraph
#: modules/configuration.org:306
msgid ""
"User-level Nix settings, managed through home-manager because they belong to "
"the user's environment rather than the system configuration."
msgstr ""

#. type: paragraph
#: modules/configuration.org:309
msgid ""
"XDG base directories are enabled to keep =~/.nix-defexpr= and "
"=~/.nix-profile= under =~/.config/nix/= and =~/.local/state/nix/=, "
"respectively, reducing dotfile clutter in =$HOME=."
msgstr ""

#. type: paragraph
#: modules/configuration.org:313
msgid ""
"The =result= symlink is added to git ignores because =nix build= creates "
"=result= symlinks in the project root by default, and these should never be "
"committed. This applies to the user's global gitignore, not to any specific "
"repository."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:317
#, no-wrap
msgid "nix-home-manager"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:319
#, no-wrap
msgid ""
"flake.modules.homeManager.nix =\n"
"  {\n"
"    config,\n"
"    lib,\n"
"    ...\n"
"  }:\n"
"  let\n"
"    cfg = config.my.nix;\n"
"  in\n"
"  {\n"
"    options.my.nix.enable = lib.mkEnableOption \"nix\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:331
#, no-wrap
msgid ""
"config = lib.mkIf cfg.enable {\n"
"  nix.settings.use-xdg-base-directories = config.xdg.enable;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:334
#, no-wrap
msgid ""
"    programs.git.ignores = [ \"result\" ];\n"
"  };\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:339 modules/configuration.org:451
#, no-wrap
msgid "Networking"
msgstr ""

#. type: heading **
#: modules/configuration.org:341
#, no-wrap
msgid "Tailscale"
msgstr ""

#. type: paragraph
#: modules/configuration.org:343
msgid ""
"Opinionated Tailscale VPN configuration for NixOS systems. This module "
"provides sensible defaults for running Tailscale with MagicDNS, SSH access, "
"and proper firewall configuration."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:352
#, no-wrap
msgid ""
"{ ... }:\n"
"{\n"
"  flake.modules.nixos.tailscale =\n"
"    { config, lib, ... }:\n"
"    let\n"
"      cfg = config.my.services.tailscale;\n"
"    in\n"
"    {\n"
"      <<tailscale-options>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:362
#, no-wrap
msgid ""
"      <<tailscale-config>>\n"
"    };\n"
"}"
msgstr ""

#. type: paragraph
#: modules/configuration.org:369
msgid "Module options for controlling Tailscale behavior."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:371
#, no-wrap
msgid "tailscale-options"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:373
#, no-wrap
msgid ""
"options.my.services.tailscale = {\n"
"  enable = lib.mkEnableOption \"Tailscale VPN\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:376
#, no-wrap
msgid ""
"  <<configureResolver-option>>\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:380
#, no-wrap
msgid "configureResolver"
msgstr ""

#. type: paragraph
#: modules/configuration.org:382
msgid ""
"Desktop systems may experience DNS resolution failures after "
"suspend/resume. When the system resumes, external domain resolution (e.g., "
"github.com) fails while Tailnet hostnames continue to work. This is a known "
"issue with Tailscale's DNS state management during network transitions."
msgstr ""

#. type: paragraph
#: modules/configuration.org:386
msgid ""
"Enabling =configureResolver= activates systemd-resolved, which helps "
"mitigate DNS resolution issues after suspend/resume. While this doesn't "
"completely eliminate the issue (the upstream bug remains open), it provides "
"the most reliable MagicDNS experience."
msgstr ""

#. type: paragraph
#: modules/configuration.org:390
msgid ""
"For headless servers, this option is typically unnecessary because servers "
"don't suspend, and thus never encounter this resume-related DNS bug."
msgstr ""

#. type: paragraph
#: modules/configuration.org:393
msgid ""
"See "
"[[https://github.com/tailscale/tailscale/issues/4254][tailscale/tailscale#4254]] "
"for the upstream discussion."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:395
#, no-wrap
msgid "configureResolver-option"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:397
#, no-wrap
msgid ""
"configureResolver = lib.mkOption {\n"
"  type = lib.types.bool;\n"
"  default = false;\n"
"  description = ''\n"
"    Enable systemd-resolved for Tailscale DNS.\n"
"    Recommended for desktop systems to mitigate DNS failures after "
"suspend/resume.\n"
"    https://github.com/tailscale/tailscale/issues/4254\n"
"  '';\n"
"};"
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:410
#, no-wrap
msgid "tailscale-config"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:412
#, no-wrap
msgid ""
"config = lib.mkIf cfg.enable (\n"
"  lib.mkMerge [\n"
"    {\n"
"      <<tailscale-service>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:417
#, no-wrap
msgid "<<tailscale-networking>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:419
#, no-wrap
msgid ""
"      <<tailscale-secrets>>\n"
"    }\n"
"    <<tailscale-resolver>>\n"
"  ]\n"
");"
msgstr ""

#. type: heading ****
#: modules/configuration.org:426
#, no-wrap
msgid "Service Settings"
msgstr ""

#. type: paragraph
#: modules/configuration.org:428
msgid "Core Tailscale service configuration."
msgstr ""

#. type: paragraph
#: modules/configuration.org:430
msgid ""
"=useRoutingFeatures = \"server\"= enables this machine to act as a subnet "
"router or exit node.  All machines in this configuration can potentially "
"serve as exit nodes for other devices, providing flexibility when traveling "
"or on restricted networks."
msgstr ""

#. type: paragraph
#: modules/configuration.org:434
msgid ""
"=authKeyFile= points to a SOPS-managed secret containing a Tailscale auth "
"key. Using auth keys enables unattended authentication, which is essential "
"for automated deployments and GitOps workflows with tools like comin."
msgstr ""

#. type: paragraph
#: modules/configuration.org:438
msgid ""
"=--ssh= enables Tailscale SSH, allowing SSH access over the Tailscale "
"network without managing SSH keys or exposing port 22 to the public "
"internet."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:441
#, no-wrap
msgid "tailscale-service"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:443
#, no-wrap
msgid ""
"services.tailscale = {\n"
"  enable = true;\n"
"  useRoutingFeatures = \"server\";\n"
"  authKeyFile = config.sops.secrets.tailscale-authkey.path;\n"
"  extraUpFlags = [ \"--ssh\" ];\n"
"};"
msgstr ""

#. type: paragraph
#: modules/configuration.org:453
msgid "Firewall and DNS configuration for Tailscale integration."
msgstr ""

#. type: paragraph
#: modules/configuration.org:455
msgid ""
"The =tailscale0= interface is trusted because all traffic on this interface "
"is authenticated by Tailscale. This allows services to be exposed only to "
"the tailnet without additional firewall rules."
msgstr ""

#. type: paragraph
#: modules/configuration.org:459
msgid ""
"=100.100.100.100= is Tailscale's MagicDNS resolver, enabling resolution of "
"tailnet hostnames (e.g., =hostname.tail4108.ts.net=). =8.8.8.8= provides "
"fallback for non-tailnet queries, though in practice MagicDNS handles "
"forwarding to upstream resolvers."
msgstr ""

#. type: paragraph
#: modules/configuration.org:463
msgid ""
"The search domain is the tailnet domain, allowing short hostnames (e.g., "
"=ssh manyara= instead of =ssh manyara.tail4108.ts.net=)."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:466
#, no-wrap
msgid "tailscale-networking"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:468
#, no-wrap
msgid ""
"networking = {\n"
"  firewall = {\n"
"    trustedInterfaces = [ \"tailscale0\" ];\n"
"    allowedUDPPorts = [ config.services.tailscale.port ];\n"
"  };\n"
"  nameservers = [\n"
"    \"100.100.100.100\"\n"
"    \"8.8.8.8\"\n"
"  ];\n"
"  search = [ \"tail4108.ts.net\" ];\n"
"};"
msgstr ""

#. type: heading ****
#: modules/configuration.org:481
#, no-wrap
msgid "Secrets"
msgstr ""

#. type: paragraph
#: modules/configuration.org:483
msgid ""
"SOPS secret declaration for the Tailscale auth key. The actual key is stored "
"encrypted in the repository's secrets file and decrypted at activation time."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:486
#, no-wrap
msgid "tailscale-secrets"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:488
#, no-wrap
msgid "sops.secrets.tailscale-authkey = { };"
msgstr ""

#. type: heading ****
#: modules/configuration.org:491
#, no-wrap
msgid "Resolver"
msgstr ""

#. type: paragraph
#: modules/configuration.org:493
msgid ""
"Conditional systemd-resolved configuration. Only enabled when "
"=configureResolver= is true, typically on desktop systems that "
"suspend/resume."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:496
#, no-wrap
msgid "tailscale-resolver"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:498
#, no-wrap
msgid ""
"(lib.mkIf cfg.configureResolver {\n"
"  services.resolved.enable = cfg.configureResolver;\n"
"})"
msgstr ""

#. type: heading *
#: modules/configuration.org:503
#, no-wrap
msgid "File Synchronization"
msgstr ""

#. type: heading **
#: modules/configuration.org:505
#, no-wrap
msgid "org-sync"
msgstr ""

#. type: paragraph
#: modules/configuration.org:507
msgid ""
"I keep my org notes in =~/dropbox/org= and have synced them across my "
"desktop and laptops through Dropbox. I added Syncthing so the hermes-agent "
"VM can read the same notes, and I plan to drop Dropbox and rely on Syncthing "
"alone once it has proven itself."
msgstr ""

#. type: paragraph
#: modules/configuration.org:512
msgid ""
"This is a user-level =services.syncthing= instance, separate from the "
"system-level daemon kilimanjaro already runs; its ports are shifted off the "
"defaults so the two do not collide."
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:522
#, no-wrap
msgid ""
"{ ... }:\n"
"{\n"
"  flake.modules.homeManager.\"org-sync\" =\n"
"    {\n"
"      config,\n"
"      lib,\n"
"      ...\n"
"    }:\n"
"    let\n"
"      cfg = config.my.services.org-sync;\n"
"    in\n"
"    {\n"
"      options.my.services.org-sync = {\n"
"        enable = lib.mkEnableOption \"syncing the org folder across the "
"user's devices\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:537
#, no-wrap
msgid ""
"  devices = lib.mkOption {\n"
"    type = lib.types.attrsOf (\n"
"      lib.types.submodule {\n"
"        options.id = lib.mkOption {\n"
"          type = lib.types.str;\n"
"          description = \"Syncthing device ID.\";\n"
"        };\n"
"      }\n"
"    );\n"
"    default = { };\n"
"    description = \"Peer devices that participate in the org folder.\";\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:551
#, no-wrap
msgid ""
"      config = lib.mkIf cfg.enable {\n"
"        services.syncthing = {\n"
"          enable = true;\n"
"          guiAddress = \"127.0.0.1:8385\";\n"
"          overrideDevices = true;\n"
"          overrideFolders = true;\n"
"          settings = {\n"
"            options.listenAddresses = [\n"
"              \"tcp://0.0.0.0:22001\"\n"
"              \"quic://0.0.0.0:22001\"\n"
"            ];\n"
"            devices = cfg.devices;\n"
"            folders.org = {\n"
"              path = \"${config.home.homeDirectory}/dropbox/org\";\n"
"              devices = lib.attrNames cfg.devices;\n"
"            };\n"
"          };\n"
"        };\n"
"      };\n"
"    };\n"
"}"
msgstr ""

#. type: heading *
#: modules/configuration.org:574
#, no-wrap
msgid "Shell"
msgstr ""

#. type: paragraph
#: modules/configuration.org:576
msgid ""
"Interactive shells and scripting shells serve different purposes. An "
"interactive shell does not need to be POSIX-compatible — what matters is "
"usability, broad environment support, and extensibility."
msgstr ""

#. type: heading **
#: modules/configuration.org:580
#, no-wrap
msgid "Fish"
msgstr ""

#. type: paragraph
#: modules/configuration.org:582
msgid ""
"Fish is the primary interactive shell, chosen for its out-of-the-box "
"experience: syntax highlighting, autosuggestions, and tab completions work "
"without configuration or plugins. Among shells with broad environment and "
"software support, fish provides the most convenient and extensible "
"interactive experience with the least setup effort."
msgstr ""

#. type: paragraph
#: modules/configuration.org:587
msgid ""
"Both NixOS and nix-darwin hand fish its environment by sourcing each "
"=environment.*Init= snippet -- and on NixOS the whole session environment -- "
"through a bash foreign-env round-trip on every interactive startup. Spawning "
"bash is a fixed cost paid even when a snippet is empty; I measured ~22ms "
"across those calls on one of my NixOS hosts. So I enable =useBabelfish= to "
"translate the environment to native fish once at build time instead."
msgstr ""

#. type: keyword NAME
#: modules/configuration.org:594
#, no-wrap
msgid "useBabelfish"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:596
#, no-wrap
msgid "programs.fish.useBabelfish = true;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:605
#, no-wrap
msgid ""
"{ ... }:\n"
"let\n"
"  systemModule =\n"
"    {\n"
"      config,\n"
"      lib,\n"
"      pkgs,\n"
"      ...\n"
"    }:\n"
"    {\n"
"      options.my.programs.fish.enable = lib.mkEnableOption \"fish\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:619
#, no-wrap
msgid ""
"  config = lib.mkIf config.my.programs.fish.enable {\n"
"    programs.fish.enable = true;\n"
"    environment.shells = [ pkgs.fish ];\n"
"    users.users.${config.my.username}.shell = pkgs.fish;\n"
"    <<useBabelfish>>\n"
"  };\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:628
#, no-wrap
msgid ""
"darwinModule =\n"
"  {\n"
"    config,\n"
"    lib,\n"
"    ...\n"
"  }:\n"
"  {\n"
"    imports = [ systemModule ];"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:637
#, no-wrap
msgid ""
"config = lib.mkIf config.my.programs.fish.enable {\n"
"  programs.fish.shellInit = ''\n"
"    if test -e '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.fish' "
"&& test -n \"$SSH_CONNECTION\"\n"
"      source '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.fish'\n"
"    end\n"
"  '';"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:650
#, no-wrap
msgid ""
"        users.users.${config.my.username}.uid = lib.mkDefault 501;\n"
"        users.knownUsers = [ config.my.username ];\n"
"      };\n"
"    };\n"
"in\n"
"{\n"
"  flake.modules.nixos.fish = systemModule;\n"
"  flake.modules.darwin.fish = darwinModule;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:659
#, no-wrap
msgid ""
"flake.modules.homeManager.fish =\n"
"  {\n"
"    config,\n"
"    lib,\n"
"    pkgs,\n"
"    ...\n"
"  }:\n"
"  let\n"
"    <<fish-any-nix-shell>>\n"
"  in\n"
"  {\n"
"    options.my.programs.fish.enable = lib.mkEnableOption \"fish\";"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:672
#, no-wrap
msgid ""
"config = lib.mkIf config.my.programs.fish.enable {\n"
"  programs.fish = {\n"
"    enable = true;"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:676
#, no-wrap
msgid "<<fish-interactive-shell-init>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:678
#, no-wrap
msgid "<<fish-abbreviations>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:680
#, no-wrap
msgid "<<fish-functions>>"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:682
#, no-wrap
msgid ""
"  <<fish-plugins>>\n"
"};"
msgstr ""

#. type: paragraph in src
#: modules/configuration.org:685
#, no-wrap
msgid ""
"        xdg.configFile = {\n"
"          \"fish/functions/nix.fish\".source = anyNixShellFunction "
"\"nix\";\n"
"          \"fish/functions/nix-shell.fish\".source = anyNixShellFunction "
"\"nix-shell\";\n"
"        };\n"
"      };\n"
"    };\n"
"}"
msgstr ""

#. type: heading ***
#: modules/configuration.org:694
#, no-wrap
msgid "Interactive Shell Init"
msgstr ""

#. type: paragraph
#: modules/configuration.org:696
msgid ""
"Settings applied when fish starts an interactive session: keybindings, "
"plugin configuration, environment variables, and shell integrations."
msgstr ""

